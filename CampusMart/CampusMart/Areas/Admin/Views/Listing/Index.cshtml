@{
    ViewData["Title"] = "Listing Approvals";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var stallItems = ViewBag.StallItems as IEnumerable<CampusMart.Models.Entities.StallItem> ?? new List<CampusMart.Models.Entities.StallItem>();
    var products = ViewBag.Products as IEnumerable<CampusMart.Models.Entities.Product> ?? new List<CampusMart.Models.Entities.Product>();
}

<h2 class="section-title" style="margin-top:0;">Listings & Approvals</h2>
<div class="section-subtitle">Review and manage items submitted by students (both Stall items and User Peer-to-Peer selling).</div>

<div style="margin-top:24px;">
    <h3 style="color:var(--primary); margin-bottom:12px;">Stall Item Listings</h3>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Item Image</th>
                    <th>Item Name</th>
                    <th>Stall (Seller)</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in stallItems)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" style="width: 40px; height: 40px; border-radius: 8px; object-fit: cover;" />
                            }
                            else
                            {
                                <div style="width: 40px; height: 40px; border-radius: 8px; background: #222; display: flex; align-items: center; justify-content: center; font-size: 20px;">📦</div>
                            }
                        </td>
                        <td>
                            <div style="font-weight: 700;">@item.Name</div>
                            <div style="font-size: 11px; color: var(--text-muted);">Stock: @item.Stock</div>
                        </td>
                        <td>
                            <div style="font-weight: 700;">@item.Stall?.Name</div>
                            <div style="font-size: 11px; color: var(--text-muted);">@item.Stall?.OwnerName</div>
                        </td>
                        <td style="font-weight: 700; color: #79e7a3;">₱@item.Price.ToString("0.00")</td>
                        <td>
                            @if (item.Status == "Approved")
                            {
                                <span style="color: #79e7a3; font-weight: 700; background: rgba(121, 231, 163, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 12px;">@item.Status</span>
                            }
                            else if (item.Status == "Rejected")
                            {
                                <span style="color: #ff6b6b; font-weight: 700; background: rgba(255, 107, 107, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 12px;">@item.Status</span>
                            }
                            else
                            {
                                <span style="color: #ffd54f; font-weight: 700; background: rgba(255, 213, 79, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 12px;">@item.Status</span>
                            }
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <div style="display: flex; gap: 8px;">
                                    <form asp-area="Admin" asp-controller="Listing" asp-action="Approve" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn" style="background: #79e7a3; color: #111; border: none; padding: 6px 12px; border-radius: 6px; font-weight: 600; cursor: pointer;">Approve</button>
                                    </form>
                                    <form asp-area="Admin" asp-controller="Listing" asp-action="Reject" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn warn" style="padding: 6px 12px; border-radius: 6px; font-weight: 600;">Reject</button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
                @if(!stallItems.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 24px;">No stall listings found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <h3 style="color:var(--primary); margin-bottom:12px; margin-top:40px;">Student "Sell" Postings</h3>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Item Image</th>
                    <th>Product Name</th>
                    <th>Seller</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prod in products)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(prod.ImageUrl))
                            {
                                <img src="@prod.ImageUrl" alt="@prod.Name" style="width: 40px; height: 40px; border-radius: 8px; object-fit: cover;" />
                            }
                            else
                            {
                                <div style="width: 40px; height: 40px; border-radius: 8px; background: #222; display: flex; align-items: center; justify-content: center; font-size: 20px;">🛒</div>
                            }
                        </td>
                        <td>
                            <div style="font-weight: 700;">@prod.Name</div>
                            <div style="font-size: 11px; color: var(--text-muted);">Stock: @prod.Stock &middot; @prod.Category?.Name</div>
                        </td>
                        <td>
                            <div style="font-weight: 700;">@prod.Seller?.FullName</div>
                            <div style="font-size: 11px; color: var(--text-muted);">@prod.Seller?.StudentId</div>
                        </td>
                        <td style="font-weight: 700; color: #79e7a3;">₱@prod.Price.ToString("0.00")</td>
                        <td>
                            @if (prod.Status == "Approved")
                            {
                                <span style="color: #79e7a3; font-weight: 700; background: rgba(121, 231, 163, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 12px;">@prod.Status</span>
                            }
                            else if (prod.Status == "Rejected")
                            {
                                <span style="color: #ff6b6b; font-weight: 700; background: rgba(255, 107, 107, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 12px;">@prod.Status</span>
                            }
                            else
                            {
                                <span style="color: #ffd54f; font-weight: 700; background: rgba(255, 213, 79, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 12px;">@prod.Status</span>
                            }
                        </td>
                        <td>
                            @if (prod.Status == "Pending")
                            {
                                <div style="display: flex; gap: 8px;">
                                    <form asp-area="Admin" asp-controller="Listing" asp-action="ApproveProduct" method="post">
                                        <input type="hidden" name="id" value="@prod.Id" />
                                        <button type="submit" class="btn" style="background: #79e7a3; color: #111; border: none; padding: 6px 12px; border-radius: 6px; font-weight: 600; cursor: pointer;">Approve</button>
                                    </form>
                                    <form asp-area="Admin" asp-controller="Listing" asp-action="RejectProduct" method="post">
                                        <input type="hidden" name="id" value="@prod.Id" />
                                        <button type="submit" class="btn warn" style="padding: 6px 12px; border-radius: 6px; font-weight: 600;">Reject</button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
                @if(!products.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 24px;">No student postings found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
