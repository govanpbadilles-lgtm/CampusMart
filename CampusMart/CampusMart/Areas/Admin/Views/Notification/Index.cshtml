@{
    ViewData["Title"] = "Admin Notifications";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="display: flex; justify-content: space-between; align-items: flex-end;">
    <div>
        <h2 class="section-title" style="margin-top:0;">Notifications</h2>
        <div class="section-subtitle">System alerts and administrative notifications.</div>
    </div>
    <button class="btn">Mark All as Read</button>
</div>

<div class="table-wrap" style="margin-top: 24px; padding: 16px;">
    <div style="display:flex; align-items:flex-start; gap: 16px; padding: 12px; border-bottom: 1px solid var(--border-subtle);">
        <div style="font-size: 24px;">🔔</div>
        <div>
            <div style="font-weight: 700; font-size: 16px; margin-bottom: 4px;">New Store Application</div>
            <div style="color: var(--text-muted); font-size: 14px; margin-bottom: 4px;">A new store application was submitted by John Doe.</div>
            <div style="font-size: 12px; color: #79e7a3;">2 hours ago</div>
        </div>
    </div>
    
    <div style="display:flex; align-items:flex-start; gap: 16px; padding: 12px; border-bottom: 1px solid var(--border-subtle);">
        <div style="font-size: 24px;">⚠️</div>
        <div>
            <div style="font-weight: 700; font-size: 16px; margin-bottom: 4px;">High Server Load</div>
            <div style="color: var(--text-muted); font-size: 14px; margin-bottom: 4px;">Server CPU usage exceeded 80% for 5 minutes.</div>
            <div style="font-size: 12px; color: #ff8d8d;">5 hours ago</div>
        </div>
    </div>

    <div style="display:flex; align-items:flex-start; gap: 16px; padding: 12px;">
        <div style="font-size: 24px;">✅</div>
        <div>
            <div style="font-weight: 700; font-size: 16px; margin-bottom: 4px;">System Update Complete</div>
            <div style="color: var(--text-muted); font-size: 14px; margin-bottom: 4px;">The CampusMart system was successfully updated to v1.2.</div>
            <div style="font-size: 12px; color: #79e7a3;">1 day ago</div>
        </div>
    </div>
</div>
