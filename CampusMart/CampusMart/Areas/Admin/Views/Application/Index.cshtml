@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Store Applications";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="section-title" style="margin-top:0;">Pending Store Applications</h2>
<div class="section-subtitle">Review and manage stall requests from students.</div>

<div class="table-wrap" style="margin-top: 24px;">
    <table>
        <thead>
            <tr>
                <th>Student Name</th>
                <th>Requested Store Name</th>
                <th>Category</th>
                <th>Date Applied</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in Model)
            {
                <tr>
                    <td>@app.StudentName</td>
                    <td>@app.StoreName</td>
                    <td><span class="pill @app.Category.ToLower()">@app.Category</span></td>
                    <td>@app.DateApplied.ToString("MMM dd, yyyy")</td>
                    <td><span style="color: #ffd54f; font-weight: 700;">@app.Status</span></td>
                    <td>
                        <button class="btn" style="background: var(--success); color: #111; border: none; padding: 6px 12px; border-radius: 6px; font-weight: 600; cursor: pointer; margin-right: 8px;">Approve</button>
                        <button class="btn warn" style="padding: 6px 12px; border-radius: 6px;">Reject</button>
                    </td>
                </tr>
            }
            @if(!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align: center; padding: 24px;">No pending applications found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
