@{
    ViewData["Title"] = "Admin Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header-row">
    <div>
        <h2 class="section-title">System Configuration</h2>
        <p class="section-subtitle">Manage global parameters and platform-wide administrative settings.</p>
    </div>
</div>

<div style="background: var(--admin-card-bg); border: 1px solid var(--admin-border); border-radius: var(--border-radius-lg); padding: 40px; margin-top: 32px; max-width: 800px;">
    <h3 style="font-size: 20px; font-weight: 800; color: #fff; margin-bottom: 32px; display: flex; align-items: center; gap: 12px;">
        <i class="bi bi-sliders" style="color: var(--admin-primary);"></i> General Platform Settings
    </h3>
    
    <form>
        <div class="row g-4">
            <div class="col-md-6">
                <label class="modal-label">Platform Identity</label>
                <input type="text" value="CampusMart" class="modal-input" placeholder="Enter platform name">
            </div>
            <div class="col-md-6">
                <label class="modal-label">Support Channel (Email)</label>
                <input type="email" value="admin@campusmart.local" class="modal-input" placeholder="admin@example.com">
            </div>
            <div class="col-12">
                <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--admin-border); border-radius: var(--border-radius-md); padding: 24px;">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <div>
                            <div style="font-weight: 700; color: #fff; margin-bottom: 4px;">Maintenance Protocol</div>
                            <div style="font-size: 13px; color: var(--text-dim);">When enabled, only administrators can access the platform.</div>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="maintMode" style="width: 44px; height: 22px; cursor: pointer; background-color: rgba(255,255,255,0.1); border-color: var(--admin-border);">
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12" style="margin-top: 40px; pt-4; border-top: 1px solid var(--admin-border);">
                <button type="button" class="cm-btn-primary">
                    <i class="bi bi-save-fill"></i> Commit Platform Changes
                </button>
            </div>
        </div>
    </form>
</div>
