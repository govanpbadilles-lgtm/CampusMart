@model IEnumerable<CampusMart.Models.Entities.AcademicResource>
@{
    ViewData["Title"] = "Academic Needs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-container">
    <div class="form-header animate-fade-in" style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 class="form-title">Academic Needs</h1>
            <p class="form-subtitle">Post and manage academic notices, resources, and requirements for students.</p>
        </div>
        <a asp-action="Create" class="btn" style="background: var(--primary); color: #000; font-weight: bold; border: none; padding: 12px 24px; border-radius: 8px; cursor: pointer; text-decoration: none; display: inline-block;">
            + Create Post
        </a>
    </div>

    <div class="stalls-grid animate-fade-in delay-2" style="margin-top: 30px; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        @if (Model != null && Model.Any())
        {
            foreach (var resource in Model)
            {
                <div class="stall-card" style="background: #1a1a1f; border: 1px solid var(--border-subtle); border-radius: 12px; overflow: hidden; display: flex; flex-direction: column;">
                    @if (!string.IsNullOrEmpty(resource.ImageUrl))
                    {
                        <div style="height: 160px; position: relative;">
                            <img src="@resource.ImageUrl" alt="@resource.Title" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;">
                        </div>
                    }
                    <div style="padding: 20px; flex: 1; display: flex; flex-direction: column;">
                        <h4 style="font-size: 18px; margin-bottom: 8px; color: #fff;">@resource.Title</h4>
                        <p style="font-size:13px; color:var(--text-muted); line-height: 1.5; margin-bottom:16px; flex: 1;">@resource.Description</p>
                        
                        <div style="display:flex; justify-content:space-between; align-items:center; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px;">
                            <span style="font-size: 12px; color: var(--text-muted);">@resource.CreatedAt.ToString("MMM dd, yyyy")</span>
                            <form asp-action="Delete" method="post" style="margin: 0;" onsubmit="return confirm('Delete this post?');">
                                <input type="hidden" name="id" value="@resource.Id" />
                                <button type="submit" style="background: transparent; color: #ef4444; border: none; font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: underline;">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column:1/-1; text-align:center; padding:60px 0; color:var(--text-muted); background:#141417; border-radius:12px; border:1px dashed var(--border-subtle);">
                <span style="font-size:48px; display:block; margin-bottom:12px;">📚</span>
                <h3 style="font-weight:700; color:#fff; margin-bottom: 8px;">No Academic Posts</h3>
                <p>You haven't posted any academic notices yet.</p>
            </div>
        }
    </div>
</div>


