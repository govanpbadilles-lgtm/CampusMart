@{
    ViewData["Title"] = "Floor Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="metrics">
    <div class="metric-card">
        <div class="metric-label">Total Active Stalls</div>
        <div class="metric-value" id="totalActiveStalls">0</div>
        <div class="metric-sub">+3 this month</div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Revenue Per Floor (Avg)</div>
        <div class="metric-value">$12.4k</div>
        <div class="metric-sub">+8% vs last week</div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Pending Applications</div>
        <div class="metric-value">7</div>
        <div class="metric-sub">Requires review</div>
    </div>
</div>

<div class="floor-panel">
    <div>
        <h2 class="section-title" style="margin-top:0;">Select Floor</h2>
        <div class="floor-buttons" id="floorButtons"></div>
    </div>
    <div class="capacity">
        <div id="capacityLabel">Floor 1 Capacity</div>
        <div><strong id="capacityUsed">0</strong><span id="capacityTotal">/ 0 occupied</span></div>
        <div class="capacity-bar"><div class="capacity-fill" id="capacityFill"></div></div>
    </div>
</div>

<h2 class="section-title" id="stallsHeader">Active Stalls</h2>
<div class="section-subtitle">Manage current tenants and stall status.</div>
<div class="stall-grid" id="stallGrid"></div>

@section Scripts {
    <script src="~/js/floor-management.js" asp-append-version="true"></script>
}

<!-- Edit Stall Modal -->
<div class="modal-overlay" id="editStallModal" style="display:none;">
    <div class="profile-modal" style="width:400px;">
        <div class="modal-header">
            <h2 class="modal-title">Edit Stall</h2>
            <button class="close-modal" id="closeEditModal">&times;</button>
        </div>
        <div class="modal-form-group">
            <label class="modal-label">Stall Name</label>
            <input type="text" class="modal-input" id="editStallName">
        </div>
        <div class="modal-form-group">
            <label class="modal-label">Owner</label>
            <input type="text" class="modal-input" id="editStallOwner">
        </div>
        <div style="display:flex;gap:12px;margin-top:16px;">
            <button class="btn-save" id="saveStallBtn" style="flex:1;">Save Changes</button>
            <button class="btn-outline" id="cancelEditBtn" style="flex:1;">Cancel</button>
        </div>
    </div>
</div>

