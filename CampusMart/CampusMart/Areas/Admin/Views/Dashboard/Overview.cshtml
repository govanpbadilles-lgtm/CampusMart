@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="section-title">Dashboard Overview</h2>
<div class="panel">
    <h3 class="panel-title">Admin Summary</h3>
    <div class="kpi-grid">
        <div class="kpi-box"><div class="num" id="dashStalls">0</div><div class="lbl">Active Stalls</div></div>
        <div class="kpi-box"><div class="num" id="dashStudents">3</div><div class="lbl">Students</div></div>
        <div class="kpi-box"><div class="num">7</div><div class="lbl">Pending Requests</div></div>
        <div class="kpi-box"><div class="num">$12.4k</div><div class="lbl">Avg Floor Revenue</div></div>
    </div>
</div>
<div class="panel">
    <h3 class="panel-title">Quick Actions</h3>
    <div class="inline-actions">
        <a asp-controller="Dashboard" asp-action="Index" class="btn">Open Floor Management</a>
        <a asp-controller="UserManagement" asp-action="Index" class="btn">Review Student Directory</a>
    </div>
</div>

@section Scripts {
    <script src="~/js/floor-management.js" asp-append-version="true"></script>
}
