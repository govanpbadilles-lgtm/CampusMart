@model CampusMart.Models.Entities.RentalCategory
@{
    ViewData["Title"] = "Create Rental Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/rental-create-category.css" asp-append-version="true" />

<div class="create-category-container">
    <div class="page-header">
        <a asp-area="Admin" asp-controller="Rental" asp-action="Index">
            ← Back to Rentals
        </a>
    </div>

    <h1 class="page-title">Create Rental Category</h1>
    <p class="page-subtitle">Set up a new category to organize rental items (e.g., "Lab Equipment", "Meeting Rooms", "Sports Gear")</p>

    <form asp-area="Admin" asp-controller="Rental" asp-action="CreateCategory" method="post" class="category-form">
        @Html.AntiForgeryToken()

        <!-- Category Name Field -->
        <div class="form-group">
            <label for="categoryName">Category Name *</label>
            <input type="text" id="categoryName" name="Name" value="@Model?.Name" required 
                   placeholder="e.g., Science Equipment, Meeting Rooms" />
        </div>

        <!-- Icon Selection Field -->
        <div class="form-group">
            <label>Category Icon</label>
            <div class="icon-section">
                <div class="icon-display-wrapper">
                    <div class="icon-display empty" id="iconDisplay">?</div>
                    <div class="icon-info">
                        <div class="icon-title">Choose an Icon</div>
                        <div class="icon-subtitle">Select an emoji from the grid below to represent this category visually</div>
                    </div>
                </div>
                <div class="icon-picker-grid" id="iconPickerGrid">
                    @{
                        var icons = new[] { 
                            "🔬", "🧪", "🧬", "🔭",     // Science & Labs
                            "🎮", "🕹️", "🎯", "🎲",     // Games & Sports
                            "📚", "📖", "📝", "✏️",     // Books & Writing
                            "🖥️", "💻", "⌨️", "🖱️",     // Computers & Tech
                            "📷", "📹", "🎥", "📸",     // Photography & Video
                            "🎨", "🖌️", "🎭", "🖍️",     // Arts & Design
                            "🎵", "🎶", "🎸", "🎹",     // Music & Audio
                            "🏋️", "⛹️", "🤸", "🧘",     // Sports & Fitness
                            "🚗", "🚕", "🚙", "🏎️",     // Vehicles & Transport
                            "🧬", "🔬", "🧪", "⚗️",     // Lab Equipment
                            "🏢", "🏛️", "🏗️", "🏬",     // Buildings & Spaces
                            "🪑", "🛏️", "🛋️", "📦",     // Furniture & Storage
                            "🔧", "🔨", "⚒️", "🛠️",     // Tools & Maintenance
                            "⚙️", "🔩", "⚡", "🔌",     // Machinery & Electrical
                            "🎤", "📢", "📣", "🔊",     // Audio Equipment
                            "🎓", "👨‍🎓", "👩‍🎓", "📜"      // Education & Degrees
                        };
                    }
                    @foreach (var icon in icons)
                    {
                        <button type="button" class="icon-picker-btn" data-icon="@icon">@icon</button>
                    }
                </div>
            </div>
            <input type="text" name="Icon" id="iconInput" value="@(Model?.Icon ?? "")" 
                   class="icon-input-hidden" maxlength="4" />
        </div>

        <!-- Description Field -->
        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="Description" 
                      placeholder="Brief description of this category and its purpose...">@Model?.Description</textarea>
        </div>

        <!-- Action Buttons -->
        <div class="submit-section">
            <button type="submit" class="btn-submit">✓ Create Category</button>
            <a asp-area="Admin" asp-controller="Rental" asp-action="Index" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>

<script src="~/js/rental-create-category.js" asp-append-version="true"></script>
