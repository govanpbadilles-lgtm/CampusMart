@model CampusMart.Models.Entities.RentalItem
@{
    ViewData["Title"] = "Create Rental Item";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewBag.Categories as IEnumerable<CampusMart.Models.Entities.RentalCategory> ?? new List<CampusMart.Models.Entities.RentalCategory>();
}

<div class="admin-create-form">
    <a asp-area="Admin" asp-controller="Rental" asp-action="Index"
       style="color:var(--primary); text-decoration:none; font-size:13px; font-weight:600; display:inline-flex; align-items:center; gap:6px; margin-bottom:20px;">
        ← Back to Rentals
    </a>

    <h2 class="section-title" style="margin-top:0;">Create Rental Item</h2>
    <div class="section-subtitle" style="margin-bottom:24px;">Add a new item that students can rent (equipment, spaces, storage, etc.).</div>

    @if (!categories.Any())
    {
        <div style="background:rgba(255,213,79,0.1); border:1px solid rgba(255,213,79,0.3); color:var(--primary); padding:16px 20px; border-radius:10px; font-weight:600; font-size:13px;">
            ⚠️ You need to <a asp-area="Admin" asp-controller="Rental" asp-action="CreateCategory" style="color:#fff; text-decoration:underline;">create a category</a> first before adding items.
        </div>
    }
    else
    {
        <form asp-area="Admin" asp-controller="Rental" asp-action="CreateItem" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-grid">
                <div>
                    <label>Category *</label>
                    <select name="RentalCategoryId" required>
                        <option value="">— Select Category —</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Icon @cat.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Item Name *</label>
                    <input type="text" name="Name" required placeholder="e.g. Nikon ECLIPSE Ti2 Microscope" />
                </div>

                <div class="full-span">
                    <label>Description</label>
                    <textarea name="Description" rows="3" placeholder="Describe the item..."></textarea>
                </div>

                <div class="full-span">
                    <label>Item Image</label>
                    <div id="dropZone" style="width:100%; min-height:140px; background:rgba(255,255,255,0.03); border:2px dashed var(--border-subtle); border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; cursor:pointer; transition:border .3s, background .3s; position:relative; overflow:hidden;"
                         onclick="document.getElementById('imageFileInput').click()"
                         ondragover="event.preventDefault(); this.style.borderColor='var(--primary)'; this.style.background='rgba(255,215,0,0.05)';"
                         ondragleave="this.style.borderColor='var(--border-subtle)'; this.style.background='rgba(255,255,255,0.03)';"
                         ondrop="event.preventDefault(); this.style.borderColor='var(--border-subtle)'; this.style.background='rgba(255,255,255,0.03)'; handleFileDrop(event);">
                        <img id="imagePreview" src="" alt="Preview" style="display:none; max-width:100%; max-height:180px; border-radius:8px; object-fit:contain;" />
                        <div id="dropPlaceholder" style="text-align:center; padding:20px;">
                            <div style="font-size:32px; margin-bottom:6px;">📸</div>
                            <div style="font-size:13px; font-weight:600; color:#fff;">Click to upload or drag & drop</div>
                            <div style="font-size:11px; color:var(--text-muted); margin-top:4px;">JPG, PNG, WEBP — max 5MB</div>
                        </div>
                    </div>
                    <input type="file" name="imageFile" id="imageFileInput" accept="image/*" style="display:none;" onchange="previewImage(this)" />
                </div>

                <div>
                    <label>Price (₱) *</label>
                    <input type="number" name="PricePerUnit" step="0.01" min="0" required placeholder="45.00" />
                </div>
                <div>
                    <label>Per *</label>
                    <select name="PriceUnit" required>
                        <option value="hr">Per Hour</option>
                        <option value="day" selected>Per Day</option>
                        <option value="week">Per Week</option>
                        <option value="mo">Per Month</option>
                    </select>
                </div>

                <div>
                    <label>Location</label>
                    <input type="text" name="Location" placeholder="e.g. Chemistry Lab B" />
                </div>
                <div>
                    <label>Total Stock</label>
                    <input type="number" name="TotalStock" min="1" value="1" />
                </div>
            </div>

            <button type="submit"
                    style="background:var(--primary); color:#111; border:none; padding:14px 24px; border-radius:10px; font-weight:800; font-size:14px; cursor:pointer; transition:transform .2s; margin-top:24px; width:100%;"
                    onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
                Create Rental Item
            </button>
        </form>
    }
</div>

@section Scripts {
<script>
    function previewImage(input) {
        const preview = document.getElementById('imagePreview');
        const placeholder = document.getElementById('dropPlaceholder');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function handleFileDrop(e) {
        const input = document.getElementById('imageFileInput');
        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            input.files = e.dataTransfer.files;
            previewImage(input);
        }
    }
</script>
}
