@{
    ViewData["Title"] = "Rental Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewBag.Categories as IEnumerable<CampusMart.Models.Entities.RentalCategory> ?? new List<CampusMart.Models.Entities.RentalCategory>();
    var recentRentals = ViewBag.RecentRentals as IEnumerable<CampusMart.Models.Entities.Rental> ?? new List<CampusMart.Models.Entities.Rental>();
}

<div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:24px;">
    <div>
        <h2 class="section-title" style="margin-top:0;">🏷️ Rental Management</h2>
        <div class="section-subtitle">Create and manage rental categories and items. Students can browse and rent these from the Rentals page.</div>
    </div>
    <!-- ACTION BUTTONS -->
    <div style="display:flex; gap:12px;">
        <a asp-area="Admin" asp-controller="Rental" asp-action="CreateCategory"
           style="background:var(--primary); color:#111; border:none; padding:10px 20px; border-radius:8px; font-weight:700; font-size:13px; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:transform .2s;"
           onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
            ⊕ New Category
        </a>
        <a asp-area="Admin" asp-controller="Rental" asp-action="CreateItem"
           style="background:transparent; color:var(--primary); border:1px solid var(--primary); padding:10px 20px; border-radius:8px; font-weight:700; font-size:13px; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:transform .2s;"
           onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
            ⊕ New Rental Item
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background:rgba(121,231,163,0.1); border:1px solid rgba(121,231,163,0.3); color:#79e7a3; padding:12px 18px; border-radius:10px; margin-bottom:20px; font-weight:600; font-size:13px;">
        ✅ @TempData["SuccessMessage"]
    </div>
}

<!-- CATEGORIES SECTION -->
<h3 style="color:var(--primary); margin-bottom:16px;">Rental Categories</h3>

@if (!categories.Any())
{
    <div style="background:rgba(255,255,255,0.03); border:1px dashed rgba(255,255,255,0.1); border-radius:12px; padding:40px; text-align:center; color:var(--text-muted); margin-bottom:32px;">
        <div style="font-size:32px; margin-bottom:8px;">📁</div>
        <div style="font-weight:600;">No rental categories yet</div>
        <div style="font-size:13px; margin-top:4px;">Click "New Category" to create your first rental category.</div>
    </div>
}
else
{
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px; margin-bottom:32px;">
        @foreach (var cat in categories)
        {
            <div style="background:#141417; border:1px solid var(--border-subtle); border-radius:16px; padding:24px; transition:all .3s ease; position:relative; overflow:hidden;"
                 onmouseover="this.style.borderColor='var(--primary)'; this.style.transform='translateY(-2px)';" onmouseout="this.style.borderColor='var(--border-subtle)'; this.style.transform='none';">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px;">
                    <div style="display:flex; align-items:center; gap:16px;">
                        <div style="width:48px; height:48px; border-radius:12px; background:rgba(255,255,255,0.03); display:flex; align-items:center; justify-content:center; font-size:24px; border:1px solid rgba(255,255,255,0.05);">
                            @cat.Icon
                        </div>
                        <div>
                            <div style="font-weight:700; color:#fff; font-size:16px; margin-bottom:4px;">@cat.Name</div>
                            <div style="font-size:12px; color:var(--primary); font-weight:600; background:rgba(255,213,79,0.1); padding:2px 8px; border-radius:6px; display:inline-block;">@(cat.RentalItems?.Count ?? 0) items</div>
                        </div>
                    </div>
                    <form asp-area="Admin" asp-controller="Rental" asp-action="DeleteCategory" method="post" 
                          onsubmit="return confirm('Delete category &quot;@cat.Name&quot; and all its items?')">
                        <input type="hidden" name="id" value="@cat.Id" />
                        <button type="submit" style="background:rgba(255,107,107,0.1); border:none; color:#ff6b6b; border-radius:8px; width:32px; height:32px; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:14px; transition:.2s;" onmouseover="this.style.background='rgba(255,107,107,0.2)'" onmouseout="this.style.background='rgba(255,107,107,0.1)'" title="Delete Category">🗑</button>
                    </form>
                </div>
                @if (!string.IsNullOrWhiteSpace(cat.Description))
                {
                    <div style="font-size:13px; color:var(--text-muted); line-height:1.6; border-top:1px solid rgba(255,255,255,0.05); padding-top:16px; margin-top:16px;">@cat.Description</div>
                }
            </div>
        }
    </div>
}

<!-- ITEMS TABLE -->
<h3 style="color:var(--primary); margin-bottom:12px; margin-top:40px;">All Rental Items</h3>

@{
    var allItems = categories.SelectMany(c => c.RentalItems ?? new List<CampusMart.Models.Entities.RentalItem>()).OrderByDescending(i => i.CreatedAt);
}

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Image</th>
                <th>Item Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in allItems)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" style="width:40px; height:40px; border-radius:8px; object-fit:cover;" />
                        }
                        else
                        {
                            <div style="width:40px; height:40px; border-radius:8px; background:#222; display:flex; align-items:center; justify-content:center; font-size:20px;">🔧</div>
                        }
                    </td>
                    <td>
                        <div style="font-weight:700;">@item.Name</div>
                        <div style="font-size:11px; color:var(--text-muted);">@item.Location</div>
                    </td>
                    <td>
                        <span style="font-size:12px;">@item.RentalCategory?.Icon @item.RentalCategory?.Name</span>
                    </td>
                    <td style="font-weight:700; color:#79e7a3;">₱@item.PricePerUnit.ToString("0.00")/@item.PriceUnit</td>
                    <td>
                        <span style="font-weight:700;">@item.AvailableStock</span>
                        <span style="color:var(--text-muted); font-size:11px;">/ @item.TotalStock</span>
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span style="color:#79e7a3; font-weight:700; background:rgba(121,231,163,0.1); padding:4px 10px; border-radius:12px; font-size:12px;">Active</span>
                        }
                        else
                        {
                            <span style="color:#ff6b6b; font-weight:700; background:rgba(255,107,107,0.1); padding:4px 10px; border-radius:12px; font-size:12px;">Disabled</span>
                        }
                    </td>
                    <td>
                        <div style="display:flex; gap:8px;">
                            <form asp-area="Admin" asp-controller="Rental" asp-action="ToggleItem" method="post">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn" style="background:rgba(255,255,255,0.05); color:#fff; border:1px solid var(--border-subtle); padding:6px 12px; border-radius:6px; font-weight:600; cursor:pointer; font-size:11px;">
                                    @(item.IsActive ? "Disable" : "Enable")
                                </button>
                            </form>
                            <form asp-area="Admin" asp-controller="Rental" asp-action="DeleteItem" method="post" onsubmit="return confirm('Delete this item?')">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn warn" style="padding:6px 12px; border-radius:6px; font-weight:600; font-size:11px;">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!allItems.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center; padding:24px; color:var(--text-muted);">No rental items yet. Create a category first, then add items.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- RECENT BOOKINGS -->
<h3 style="color:var(--primary); margin-bottom:12px; margin-top:40px;">Recent Student Bookings</h3>
<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Student</th>
                <th>Item</th>
                <th>Dates</th>
                <th>Total</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in recentRentals)
            {
                <tr>
                    <td>
                        <div style="font-weight:700;">@r.User?.FullName</div>
                        <div style="font-size:11px; color:var(--text-muted);">@r.User?.StudentId</div>
                    </td>
                    <td>
                        <div style="font-weight:700;">@r.RentalItem?.Name</div>
                        <div style="font-size:11px; color:var(--text-muted);">@r.RentalItem?.RentalCategory?.Name</div>
                    </td>
                    <td style="font-size:12px;">
                        @r.StartDate.ToString("MMM dd") → @r.EndDate.ToString("MMM dd, yyyy")
                    </td>
                    <td style="font-weight:700; color:#79e7a3;">₱@r.TotalPrice.ToString("0.00")</td>
                    <td>
                        @if (r.Status == "Active")
                        {
                            <span style="color:#79e7a3; font-weight:700; background:rgba(121,231,163,0.1); padding:4px 10px; border-radius:12px; font-size:12px;">@r.Status</span>
                        }
                        else if (r.Status == "Overdue")
                        {
                            <span style="color:#ff6b6b; font-weight:700; background:rgba(255,107,107,0.1); padding:4px 10px; border-radius:12px; font-size:12px;">@r.Status</span>
                        }
                        else
                        {
                            <span style="color:var(--text-muted); font-weight:700; background:rgba(255,255,255,0.05); padding:4px 10px; border-radius:12px; font-size:12px;">@r.Status</span>
                        }
                    </td>
                </tr>
            }
            @if (!recentRentals.Any())
            {
                <tr>
                    <td colspan="5" style="text-align:center; padding:24px; color:var(--text-muted);">No rental bookings yet.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
