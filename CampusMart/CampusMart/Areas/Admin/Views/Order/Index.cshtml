@model IEnumerable<CampusMart.Models.Entities.Order>
@{
    ViewData["Title"] = "Store Oversight";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header-row">
    <div>
        <h2 class="section-title">Store Oversight</h2>
        <p class="section-subtitle">Monitor and manage all transactions and marketplace activity across the platform.</p>
    </div>
</div>

<div class="metrics">
    <div class="metric-card">
        <div class="metric-label">Total Platform Revenue</div>
        <div class="metric-value" style="color: #4ade80;">₱@Model.Sum(o => o.TotalAmount).ToString("N2")</div>
        <div class="metric-sub">
            <i class="bi bi-graph-up-arrow"></i> Lifetime earnings
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Transaction Count</div>
        <div class="metric-value">@Model.Count()</div>
        <div class="metric-sub">
            <i class="bi bi-cart-check-fill"></i> Total processed orders
        </div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Success Rate</div>
        @{
            var totalOrders = Model.Count();
            var completedOrders = Model.Count(o => o.Status == "Completed");
            var successRate = totalOrders > 0 ? Math.Round((double)completedOrders * 100 / totalOrders, 2) : 0;
        }
        <div class="metric-value">@successRate%</div>
        <div class="metric-sub">
            <i class="bi bi-patch-check-fill"></i> Fulfilled orders
        </div>
    </div>
</div>

<div class="table-wrap">
    <table class="cm-table">
        <thead>
            <tr>
                <th style="width: 120px;">Reference ID</th>
                <th>Order Date</th>
                <th>Purchasing Student</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var order in Model)
                {
                    <tr>
                        <td>
                            <span style="font-family: 'JetBrains Mono', monospace; font-weight: 800; color: #fff; background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 6px;">#ORD-@order.Id</span>
                        </td>
                        <td style="color: var(--text-dim); font-size: 13px;">@order.CreatedAt.ToString("MMM dd, yyyy · HH:mm")</td>
                        <td>
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <div class="avatar-placeholder" style="width: 32px; height: 32px; font-size: 12px;">
                                    @(order.User?.FullName?.Substring(0,1) ?? "U")
                                </div>
                                <div>
                                    <div style="font-weight: 700; color: #fff;">@order.User?.FullName</div>
                                    <div style="font-size: 11px; color: var(--admin-primary); font-weight: 800; text-transform: uppercase;">@order.User?.StudentId</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span style="font-weight: 800; color: #4ade80; font-size: 15px;">₱@order.TotalAmount.ToString("N2")</span>
                            <div style="font-size: 10px; color: var(--text-dim); font-weight: 700; margin-top: 2px;">via @order.PaymentMethod</div>
                        </td>
                        <td>
                            @if (order.Status == "Completed")
                            {
                                <span class="status-badge status-open"><i class="bi bi-check-circle-fill"></i> Completed</span>
                            }
                            else if (order.Status == "Pending" || order.Status == "Confirmed")
                            {
                                <span class="status-badge status-closed"><i class="bi bi-hourglass-split"></i> @order.Status</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive"><i class="bi bi-x-circle-fill"></i> @order.Status</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                @if (order.Status != "Completed" && order.Status != "Cancelled")
                                {
                                    <form asp-action="UpdateStatus" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <input type="hidden" name="status" value="Completed" />
                                        <button type="submit" class="tool-btn" style="color: #4ade80;" title="Mark as Completed">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form asp-action="UpdateStatus" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <input type="hidden" name="status" value="Cancelled" />
                                        <button type="submit" class="tool-btn" style="color: #f87171;" title="Cancel Order">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                                <a asp-action="Details" asp-route-id="@order.Id" class="tool-btn" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="DeleteOrder" method="post" style="display:inline;" onsubmit="return confirm('Permanently delete this order record?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.Id" />
                                    <button type="submit" class="tool-btn" style="color: var(--text-dim);" title="Delete Order">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <div style="opacity: 0.2; margin-bottom: 16px;"><i class="bi bi-bar-chart-line" style="font-size: 64px;"></i></div>
                        <h4 style="color: #fff; font-weight: 800;">No Transaction Data</h4>
                        <p style="color: var(--text-muted);">The platform hasn't processed any orders yet.</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
