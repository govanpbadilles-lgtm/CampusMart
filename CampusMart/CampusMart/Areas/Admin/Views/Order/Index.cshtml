@model IEnumerable<CampusMart.Models.Entities.Order>
@{
    ViewData["Title"] = "Store Oversight";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-container">
    <div class="form-header animate-fade-in">
        <h1 class="form-title">Store Oversight</h1>
        <p class="form-subtitle">Monitor and manage all transactions across the CampusMart platform.</p>
    </div>

    <div class="stats-grid animate-fade-in delay-1" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
        <div class="stat-card" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 20px;">
            <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">Total Revenue</div>
            <div style="font-size: 28px; font-weight: 800; color: #79e7a3;">₱@Model.Sum(o => o.TotalAmount).ToString("0.00")</div>
        </div>
        <div class="stat-card" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 20px;">
            <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">Total Orders</div>
            <div style="font-size: 28px; font-weight: 800; color: #fff;">@Model.Count()</div>
        </div>
        <div class="stat-card" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 20px;">
            <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 8px;">Completed Orders</div>
            <div style="font-size: 28px; font-weight: 800; color: #fff;">@Model.Count(o => o.Status == "Completed")</div>
        </div>
    </div>

    <div class="table-container animate-fade-in delay-2" style="background: #141417; border-radius: 12px; border: 1px solid var(--border-subtle); overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border-subtle); text-align: left;">
                    <th style="padding: 16px 20px; font-size: 13px; color: var(--text-muted); font-weight: 600;">Order ID</th>
                    <th style="padding: 16px 20px; font-size: 13px; color: var(--text-muted); font-weight: 600;">Date</th>
                    <th style="padding: 16px 20px; font-size: 13px; color: var(--text-muted); font-weight: 600;">Student</th>
                    <th style="padding: 16px 20px; font-size: 13px; color: var(--text-muted); font-weight: 600;">Amount</th>
                    <th style="padding: 16px 20px; font-size: 13px; color: var(--text-muted); font-weight: 600;">Status</th>
                    <th style="padding: 16px 20px; font-size: 13px; color: var(--text-muted); font-weight: 600;">Payment Method</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var order in Model)
                    {
                        <tr style="border-bottom: 1px solid var(--border-subtle); transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
                            <td style="padding: 16px 20px; font-size: 14px; font-weight: 600;">#@order.Id</td>
                            <td style="padding: 16px 20px; font-size: 14px; color: var(--text-muted);">@order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                            <td style="padding: 16px 20px; font-size: 14px;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--primary); color: #000; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 800;">
                                        @(order.User?.FullName?.Substring(0,1) ?? "U")
                                    </div>
                                    <span>@order.User?.FullName</span>
                                </div>
                            </td>
                            <td style="padding: 16px 20px; font-size: 14px; font-weight: 600; color: #79e7a3;">₱@order.TotalAmount.ToString("0.00")</td>
                            <td style="padding: 16px 20px;">
                                @{
                                    var statusColor = order.Status == "Completed" ? "#79e7a3" : order.Status == "Pending" ? "#ffd54f" : "#ff8d8d";
                                }
                                <span style="display: inline-block; padding: 4px 10px; border-radius: 99px; font-size: 12px; font-weight: 700; background: @(statusColor)22; color: @statusColor;">
                                    @order.Status
                                </span>
                            </td>
                            <td style="padding: 16px 20px; font-size: 14px; color: var(--text-muted);">@order.PaymentMethod</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="padding: 40px 20px; text-align: center; color: var(--text-muted);">
                            <div style="font-size: 32px; margin-bottom: 12px;">📊</div>
                            <div style="font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 4px;">No Orders Found</div>
                            <div>There are no transactions in the system yet.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
