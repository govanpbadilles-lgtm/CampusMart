@model CampusMart.Models.Entities.Order
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header-row">
    <div>
        <h2 class="section-title">Order #@Model.Id</h2>
        <p class="section-subtitle">Detailed transaction record and fulfillment status.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="cm-btn-outline">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-lg-8">
        <div class="panel">
            <h3 class="panel-title">Purchased Items</h3>
            <div class="table-responsive">
                <table class="cm-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl" style="width: 40px; height: 40px; border-radius: 8px; object-fit: cover;">
                                        }
                                        <span>@item.Product?.Name</span>
                                    </div>
                                </td>
                                <td>₱@item.Price.ToString("N2")</td>
                                <td>@item.Quantity</td>
                                <td style="font-weight: 700; color: #fff;">₱@((item.Price * item.Quantity).ToString("N2"))</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-800" style="color: var(--text-dim);">TOTAL AMOUNT</td>
                            <td style="font-size: 20px; font-weight: 800; color: #4ade80;">₱@Model.TotalAmount.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel mb-4">
            <h3 class="panel-title">Customer Information</h3>
            <div class="d-flex align-items-center gap-3 mb-3">
                <img src="@(Model.User?.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Model.User?.FullName}&background=222&color=fff")" style="width: 48px; height: 48px; border-radius: 12px; object-fit: cover;">
                <div>
                    <div style="font-weight: 800; color: #fff;">@Model.User?.FullName</div>
                    <div style="font-size: 12px; color: var(--admin-primary); font-weight: 800;">@Model.User?.StudentId</div>
                </div>
            </div>
            <div style="font-size: 13px; color: var(--text-dim);">
                <div class="mb-2"><i class="bi bi-envelope me-2"></i> @Model.User?.Email</div>
                <div class="mb-2"><i class="bi bi-telephone me-2"></i> @(Model.User?.PhoneNumber ?? "No phone provided")</div>
            </div>
        </div>

        <div class="panel">
            <h3 class="panel-title">Order Status</h3>
            <div class="mb-4">
                <span class="status-badge @(Model.Status == "Completed" ? "status-open" : "status-closed")" style="font-size: 14px; padding: 8px 16px;">
                    @Model.Status
                </span>
            </div>
            
            <form asp-action="UpdateStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <label style="font-size: 11px; font-weight: 800; color: var(--text-dim); text-transform: uppercase; margin-bottom: 8px; display: block;">Update Status</label>
                <select name="status" class="form-select mb-3" style="background: rgba(0,0,0,0.2); border-color: var(--admin-border); color: #fff;">
                    <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
                    <option value="Confirmed" selected="@(Model.Status == "Confirmed")">Confirmed</option>
                    <option value="Completed" selected="@(Model.Status == "Completed")">Completed</option>
                    <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
                </select>
                <button type="submit" class="cm-btn-primary w-100" style="justify-content: center;">Update Record</button>
            </form>
        </div>
    </div>
</div>
