@model IEnumerable<CampusMart.Models.Entities.AcademicResource>
@{
    ViewData["Title"] = "Academic Hub";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="dashboard-container">
    <div class="marketplace-header animate-fade-in">
        <div class="header-left">
            <h2 class="section-title">Academic Hub</h2>
            <p class="header-desc">Essential academic resources, notices, and requirements posted by the administration to help you succeed.</p>
        </div>
    </div>

    <div class="academic-feed animate-fade-in delay-2" style="margin-top: 30px; max-width: 600px; margin-left: auto; margin-right: auto;">
        @if (Model != null && Model.Any())
        {
            foreach (var resource in Model)
            {
                <div class="academic-post" style="background: #1a1a1f; border: 1px solid var(--border-subtle); border-radius: 16px; overflow: hidden; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
                    
                    <!-- Post Header -->
                    <div style="padding: 16px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid rgba(255,255,255,0.02);">
                        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 20px;">
                            🏛️
                        </div>
                        <div>
                            <div style="font-weight: 700; color: #fff; font-size: 15px;">Admin Announcements</div>
                            <div style="font-size: 12px; color: var(--text-muted);">@resource.CreatedAt.ToString("MMMM dd, yyyy • hh:mm tt")</div>
                        </div>
                    </div>

                    <!-- Image -->
                    @if (!string.IsNullOrEmpty(resource.ImageUrl))
                    {
                        <div style="width: 100%; max-height: 500px; background: #000; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                            <img src="@resource.ImageUrl" alt="@resource.Title" style="width: 100%; object-fit: contain;">
                        </div>
                    }

                    <!-- Content -->
                    <div style="padding: 20px;">
                        <h4 style="font-size: 18px; margin-bottom: 8px; color: var(--primary); font-weight: 700;">@resource.Title</h4>
                        <p style="font-size: 14px; line-height: 1.6; color: rgba(255,255,255,0.85); margin: 0;">@resource.Description</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column:1/-1; text-align:center; padding:60px 0; color:var(--text-muted); background:#141417; border-radius:12px; border:1px dashed var(--border-subtle);">
                <span style="font-size:48px; display:block; margin-bottom:12px;">📚</span>
                <h3 style="font-weight:700; color:#fff; margin-bottom: 8px;">No Academic Resources Yet</h3>
                <p>The administration hasn't posted any academic notices or resources.</p>
            </div>
        }
    </div>
</div>
