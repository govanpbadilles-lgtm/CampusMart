@model IEnumerable<CampusMart.Models.Entities.SavedItem>
@{
    ViewData["Title"] = "Saved Items";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container-xl py-5">
    <!-- PAGE HEADER -->
    <div class="mb-5 animate-fade-in">
        <span class="cm-pill mb-3">Your Collection</span>
        <h1 class="hero-title mb-2">Bookmarked Items</h1>
        <p class="text-muted fs-5">Items you've bookmarked across the marketplace for later consideration.</p>
    </div>

    <div class="row g-4 animate-fade-in delay-1">
        @if (Model != null && Model.Any())
        {
            foreach (var savedItem in Model)
            {
                var prod = savedItem.Product;
                if (prod != null)
                {
                    <div class="col-sm-6 col-lg-3" id="saved-item-@prod.Id">
                        <div class="cm-card glass-card h-100 overflow-hidden">
                            <div class="cm-card-img-wrap" style="height: 160px;">
                                <span class="badge-price-tag">₱@prod.Price.ToString("N2")</span>
                                @if (!string.IsNullOrEmpty(prod.ImageUrl))
                                {
                                    <img src="@prod.ImageUrl" alt="@prod.Name" class="cm-card-img">
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark">
                                        <i class="bi bi-box-seam fs-1 text-muted opacity-25"></i>
                                    </div>
                                }
                            </div>
                            <div class="cm-card-body p-3">
                                <h5 class="cm-card-title mb-1 fs-6">@prod.Name</h5>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted x-small">Saved @savedItem.CreatedAt.ToString("MMM dd")</span>
                                    <span class="text-muted x-small">Stock: @prod.Stock</span>
                                </div>
                                @if (prod.Stall != null)
                                {
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <i class="bi bi-shop text-warning x-small"></i>
                                        <span class="text-white x-small fw-600">@prod.Stall.Name</span>
                                    </div>
                                }
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn-save-circle active btn-unsave" data-id="@prod.Id" title="Remove from saved">
                                        <i class="bi bi-heart-fill"></i>
                                    </button>
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1">
                                        <input type="hidden" name="productId" value="@prod.Id" />
                                        <button type="submit" class="cm-btn-outline w-100 py-2 fs-7 px-0 justify-content-center">Add to Cart</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="glass-card p-5 border-dashed">
                    <i class="bi bi-bookmark-heart fs-1 text-muted mb-3 d-block opacity-25"></i>
                    <h3 class="fw-800 text-white mb-2">No saved items yet</h3>
                    <p class="text-muted mb-4">Discover great deals and bookmark them here for later.</p>
                    <a asp-controller="UserDashboard" asp-action="Index" class="cm-btn-primary px-5 py-3">
                        Explore Marketplace <i class="bi bi-shop ms-2"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.btn-unsave').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    const productId = btn.getAttribute('data-id');
                    try {
                        const response = await fetch('/UserDashboard/ToggleSave', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `productId=${productId}`
                        });
                        const result = await response.json();
                        if (result.success && !result.saved) {
                            const cardCol = document.getElementById(`saved-item-${productId}`);
                            if (cardCol) {
                                cardCol.style.transition = "all 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
                                cardCol.style.opacity = "0";
                                cardCol.style.transform = "scale(0.8) translateY(20px)";
                                setTimeout(() => {
                                    cardCol.remove();
                                    if (document.querySelectorAll('[id^="saved-item-"]').length === 0) {
                                        location.reload();
                                    }
                                }, 400);
                            }
                        }
                    } catch (error) {
                        console.error('Error removing saved item:', error);
                    }
                });
            });
        });
    </script>
}
