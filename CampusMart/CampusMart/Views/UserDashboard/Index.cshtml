@model IEnumerable<CampusMart.Models.Entities.Stall>
@{
    ViewData["Title"] = "Campus Marketplace";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    var floors = ViewBag.Floors as List<CampusMart.Models.Entities.Floor> ?? new List<CampusMart.Models.Entities.Floor>();
    var selectedFloor = ViewBag.SelectedFloor as CampusMart.Models.Entities.Floor;
    var products = ViewBag.Products as List<CampusMart.Models.Entities.Product> ?? new List<CampusMart.Models.Entities.Product>();
    var savedProductIds = ViewBag.SavedProductIds as List<int> ?? new List<int>();
}

@functions {
    bool IsStallOpen(string openTime, string closeTime) {
        if (string.IsNullOrEmpty(openTime) || string.IsNullOrEmpty(closeTime)) return false;
        var now = DateTime.Now;
        var current = now.Hour * 60 + now.Minute;
        var parts1 = openTime.Split(':');
        var parts2 = closeTime.Split(':');
        if (parts1.Length < 2 || parts2.Length < 2) return false;
        var open = int.Parse(parts1[0]) * 60 + int.Parse(parts1[1]);
        var close = int.Parse(parts2[0]) * 60 + int.Parse(parts2[1]);
        return current >= open && current < close;
    }

    string FormatTime(string t) {
        if (string.IsNullOrEmpty(t)) return "";
        var parts = t.Split(':');
        if (parts.Length < 2) return t;
        var h = int.Parse(parts[0]);
        var m = int.Parse(parts[1]);
        var ampm = h >= 12 ? "PM" : "AM";
        var hour = h % 12;
        if (hour == 0) hour = 12;
        return $"{hour}:{m:D2} {ampm}";
    }
}

<div class="container-xl py-5">
    <!-- MARKETPLACE HEADER -->
    <div class="marketplace-hero mb-5 animate-fade-in">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="cm-pill mb-3">Live Marketplace</span>
                <h1 class="hero-title mb-3">CampusMart Marketplace</h1>
                <p class="hero-desc text-muted fs-5">Browse campus stalls and discover quality products. Your one-stop campus marketplace.</p>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="header-stats-grid">
                    <div class="glass-card p-3 text-center">
                        <span class="d-block fs-3 fw-800 text-white">@Model.Count()</span>
                        <span class="text-white small fw-700">Active Stalls</span>
                    </div>
                    <div class="glass-card p-3 text-center">
                        <span class="d-block fs-3 fw-800 text-white">@products.Count()</span>
                        <span class="text-white small fw-700">Products</span>
                    </div>
                </div>
            </div>
    </div>
</div>

    <!-- FLOOR NAVIGATION -->
    @if (floors.Any())
    {
        <div class="floor-nav-wrap mb-4 animate-fade-in delay-1">
            <h5 class="fw-800 text-white mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-layers-half text-warning"></i> Campus Floors
            </h5>
            <div class="floor-pill-tabs">
                @foreach (var f in floors)
                {
                    var isActive = selectedFloor != null && f.Id == selectedFloor.Id;
                    <a asp-action="Index" asp-route-floorId="@f.Id" class="floor-pill @(isActive ? "active" : "")">
                        <span class="floor-num">@f.FloorNumber</span>
                        <span class="floor-name">@f.Name</span>
                    </a>
                }
            </div>
        </div>
    }

    <!-- ACTIVE STALLS SECTION -->
    <div class="section-head mb-4 animate-fade-in delay-2">
        <div class="d-flex justify-content-between align-items-end">
            <div>
                <h3 class="fw-800 text-white mb-1">Active Stalls @(selectedFloor != null ? $"— {selectedFloor.Name}" : "")</h3>
                <p class="text-muted small mb-0">Browse available stalls on this floor.</p>
            </div>
            <div class="view-toggles glass-card p-1 d-flex gap-1">
                <button class="view-btn active" id="btnGridView" onclick="setStallsView('grid')"><i class="bi bi-grid-fill"></i></button>
                <button class="view-btn" id="btnListView" onclick="setStallsView('list')"><i class="bi bi-list"></i></button>
            </div>
        </div>
    </div>

    <div class="row g-4 stalls-grid animate-fade-in delay-2" id="stallsContainer">
        @if (Model != null && Model.Any())
        {
            foreach (var s in Model)
            {
                var open = IsStallOpen(s.OpenTime, s.CloseTime);
                <div class="col-md-6 col-lg-4 stall-item">
                    <div class="cm-card glass-card h-100 overflow-hidden">
                        <div class="cm-card-img-wrap">
                            @if (open) { <span class="badge-status-pill open">Open Now</span> }
                            else { <span class="badge-status-pill closed">Closed</span> }
                            
                            @if (!string.IsNullOrEmpty(s.ImageUrl))
                            {
                                <img src="@s.ImageUrl" alt="@s.Name" class="cm-card-img">
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark">
                                    <i class="bi bi-shop fs-1 text-muted opacity-25"></i>
                                </div>
                            }
                        </div>
                        <div class="cm-card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="cm-card-title mb-0">@s.Name</h4>
                                <span class="text-warning small fw-700"><i class="bi bi-bookmark-star-fill"></i> @s.Category</span>
                            </div>
                            <p class="cm-card-text line-clamp-2">@(string.IsNullOrEmpty(s.Description) ? "Quality campus stall." : s.Description)</p>
                            
                            <div class="stall-meta-info mb-3">
                                <div class="d-flex align-items-center gap-2 text-muted small mb-1">
                                    <i class="bi bi-clock-fill"></i> @FormatTime(s.OpenTime) — @FormatTime(s.CloseTime)
                                </div>
                                <div class="d-flex align-items-center gap-2 text-muted small">
                                    <i class="bi bi-box-seam"></i> @s.Products.Count product(s)
                                </div>
                            </div>

                            <a asp-controller="Stall" asp-action="Index" asp-route-id="@s.Id" class="cm-btn-primary w-100 justify-content-center">
                                Enter Stall <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="glass-card p-5">
                    <i class="bi bi-shop-window fs-1 text-muted mb-3 d-block opacity-25"></i>
                    <h3 class="fw-700">No active stalls on this floor</h3>
                    <p class="text-muted">Explore other building floors or check back later!</p>
                </div>
            </div>
        }
    </div>

    <!-- ALL PRODUCTS SECTION -->
    @if (!string.IsNullOrEmpty(ViewBag.SearchString as string) && products.Any())
    {
        <div class="section-head mb-4 mt-5 animate-fade-in delay-3">
            <h3 class="fw-800 text-white mb-1">Search Results</h3>
            <p class="text-muted small mb-0">Products matching "@ViewBag.SearchString"</p>
        </div>

        <div class="row g-4 animate-fade-in delay-3">
            @foreach (var prod in products)
            {
                <div class="col-sm-6 col-lg-3">
                    <div class="cm-card glass-card h-100 overflow-hidden">
                        <div class="cm-card-img-wrap" style="height: 160px;">
                            <span class="badge-price-tag">₱@prod.Price.ToString("0.00")</span>
                            @if (!string.IsNullOrEmpty(prod.ImageUrl))
                            {
                                <img src="@prod.ImageUrl" alt="@prod.Name" class="cm-card-img">
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark">
                                    <i class="bi bi-box-seam fs-1 text-muted opacity-25"></i>
                                </div>
                            }
                        </div>
                        <div class="cm-card-body p-3">
                            <h5 class="cm-card-title mb-1 fs-6">@prod.Name</h5>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted x-small"><i class="bi bi-tag"></i> @prod.Category?.Name</span>
                                <span class="text-muted x-small">Stock: @prod.Stock</span>
                            </div>
                            @if (prod.Stall != null)
                            {
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <i class="bi bi-shop text-warning x-small"></i>
                                    <span class="text-white x-small fw-600">@prod.Stall.Name</span>
                                </div>
                            }
                            <div class="d-flex gap-2">
                                @{ var isSaved = savedProductIds.Contains(prod.Id); }
                                <button type="button" class="btn-save-circle @(isSaved ? "active" : "")" data-id="@prod.Id" title="@(isSaved ? "Unsave" : "Save")">
                                    <i class="bi @(isSaved ? "bi-heart-fill" : "bi-heart")"></i>
                                </button>
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1">
                                    <input type="hidden" name="productId" value="@prod.Id" />
                                    <button type="submit" class="cm-btn-outline w-100 py-2 fs-7 px-0 justify-content-center" @(prod.Stock <= 0 ? "disabled" : "")>
                                        @(prod.Stock > 0 ? "Add to Cart" : "Out of Stock")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function setStallsView(viewType) {
            const container = document.getElementById('stallsContainer');
            const gridBtn = document.getElementById('btnGridView');
            const listBtn = document.getElementById('btnListView');

            if (viewType === 'list') {
                container.classList.add('list-view');
                listBtn.classList.add('active');
                gridBtn.classList.remove('active');
            } else {
                container.classList.remove('list-view');
                gridBtn.classList.add('active');
                listBtn.classList.remove('active');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.btn-save-circle').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    const productId = btn.getAttribute('data-id');
                    try {
                        const response = await fetch('/UserDashboard/ToggleSave', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `productId=${productId}`
                        });
                        const result = await response.json();
                        if (result.success) {
                            btn.classList.toggle('active');
                            const icon = btn.querySelector('i');
                            icon.classList.toggle('bi-heart');
                            icon.classList.toggle('bi-heart-fill');
                            showToast(result.saved ? 'Item added to saved!' : 'Item removed from saved.');
                        }
                    } catch (error) {
                        console.error('Error toggling save status:', error);
                    }
                });
            });
        });
    </script>
}
