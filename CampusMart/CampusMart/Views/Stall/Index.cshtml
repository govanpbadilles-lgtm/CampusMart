@model CampusMart.Models.Entities.Stall
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    var savedIds = (ViewBag.SavedProductIds as List<int>) ?? new List<int>();
}

<div class="container-xl py-5">
    <!-- PAGE HEADER -->
    <div class="mb-5 animate-fade-in">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <span class="cm-pill mb-3">Verified Stall</span>
                <h1 class="hero-title mb-1">@Model.Name</h1>
                <p class="text-muted mb-0">@Model.Description</p>
            </div>
            <a asp-controller="UserDashboard" asp-action="Index" class="cm-btn-outline py-2 px-3 fs-7 text-decoration-none">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <!-- STALL SEARCH & FILTER (inside stall) -->
    <div class="glass-card p-4 mb-5 animate-fade-in delay-1">
        <form asp-action="Index" method="get" class="row g-3 align-items-center">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text stall-search-addon bg-transparent border-end-0 border-subtle text-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control border-start-0 ps-0" placeholder="Search products in this stall..." />
                </div>
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select border-subtle">
                    <option value="">All Categories</option>
                    @if (ViewBag.AllCategories != null)
                    {
                        foreach (var cat in (List<string>)ViewBag.AllCategories)
                        {
                            <option value="@cat" selected="@(ViewBag.Category == cat ? "selected" : null)">@cat</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="cm-btn-primary w-100">Find Items</button>
            </div>
            <div class="col-md-1">
                @if (!string.IsNullOrEmpty(ViewBag.SearchString as string))
                {
                    <a asp-action="Index" asp-route-id="@Model.Id" class="cm-btn-outline w-100 text-center d-block">Reset</a>
                }
            </div>
        </form>
    </div>

    <div class="stall-details glass-card animate-fade-in delay-1 mb-5 p-4 p-md-5 position-relative overflow-hidden">
        <div class="row align-items-center g-4 position-relative z-1">
            <div class="col-md-auto">
                <div class="pic-wrapper" style="width: 120px; height: 120px;">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="profile-pic-preview" style="border-width: 3px;" />
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark" style="border-radius: 50%; border: 3px solid var(--primary);">
                            <span class="fs-1 fw-900 text-warning">@(string.IsNullOrEmpty(Model.Name) ? "S" : Model.Name.Substring(0, 1).ToUpper())</span>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md">
                <h2 class="text-white fw-900 mb-1">@Model.Name</h2>
                <span class="admin-status-pill mb-3"><i class="bi bi-shop-window"></i> @Model.Category</span>
                <div class="d-flex flex-wrap gap-3 mt-2">
                    <div class="text-muted small fw-600"><i class="bi bi-geo-alt-fill text-warning"></i> Stall @Model.StallNumber</div>
                    <div class="text-muted small fw-600"><i class="bi bi-clock-fill text-warning"></i> @Model.OpenTime - @Model.CloseTime</div>
                    @if (Model.Floor != null)
                    {
                        <div class="text-muted small fw-600"><i class="bi bi-building text-warning"></i> @Model.Floor.Name</div>
                    }
                </div>
            </div>
        </div>
        <div style="position:absolute; top:-50%; right:-10%; width:300px; height:300px; background:radial-gradient(circle,rgba(255,215,0,0.05) 0%,transparent 70%); pointer-events:none;"></div>
    </div>

    <div class="section-head mb-4 animate-fade-in delay-2">
        <h3 class="fw-800 text-white mb-1">Available Products</h3>
        <p class="text-white small mb-0 opacity-75">@Model.Products.Count item(s) available at this stall.</p>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="text-center py-5 animate-fade-in delay-3">
            <div class="glass-card p-5 d-inline-block" style="max-width: 500px;">
                <div class="empty-cart-icon mb-4">
                    <i class="bi bi-box-seam fs-1 text-muted opacity-25"></i>
                </div>
                <h3 class="text-white fw-800 mb-3">No products available</h3>
                <p class="text-muted mb-0">This stall currently has no items for sale.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 stalls-grid animate-fade-in delay-3">
            @foreach (var product in Model.Products)
            {
                var isSaved = savedIds.Contains(product.Id);
                <div class="col-sm-6 col-lg-3">
                    <div class="cm-card glass-card h-100 overflow-hidden">
                        <div class="cm-card-img-wrap" style="height: 180px;">
                            <span class="badge-price-tag">₱@product.Price.ToString("0.00")</span>
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="cm-card-img" style="object-fit:cover; width: 100%; height: 100%;">
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark">
                                    <i class="bi bi-box-seam fs-1 text-muted opacity-25"></i>
                                </div>
                            }
                        </div>
                        <div class="cm-card-body p-3 d-flex flex-column">
                            <h5 class="cm-card-title mb-1 fs-6">@product.Name</h5>
                            @if (product.Category != null)
                            {
                                <span class="x-small text-warning fw-600 mb-1">@product.Category.Icon @product.Category.Name</span>
                            }
                            <p class="cm-card-text text-white-50 x-small line-clamp-2 mb-3" style="min-height: 36px;">
                                @(string.IsNullOrEmpty(product.Description) ? "No description provided." : product.Description)
                            </p>
                            <div class="d-flex justify-content-between align-items-center mb-3 mt-auto">
                                <span class="text-white-50 x-small fw-700">Stock: @product.Stock</span>
                            </div>
                            <div class="d-flex gap-2">
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit" class="cm-btn-outline w-100 py-2 fs-7 px-0 justify-content-center" @(product.Stock <= 0 ? "disabled" : "")>
                                        @(product.Stock > 0 ? "Add to Cart" : "Out of Stock")
                                    </button>
                                </form>
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="cm-btn-outline py-2 px-3 fs-7 text-decoration-none">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn-save-circle @(isSaved ? "active" : "") btn-bookmark-toggle" data-product-id="@product.Id" title="@(isSaved ? "Remove bookmark" : "Save for later")">
                                    <i class="bi @(isSaved ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.btn-bookmark-toggle').forEach(btn => {
                btn.addEventListener('click', async function () {
                    const productId = this.dataset.productId;
                    const icon = this.querySelector('i');

                    // Prevent double clicks
                    this.disabled = true;

                    try {
                        const response = await fetch('/UserDashboard/ToggleSave', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `productId=${productId}`
                        });

                        const result = await response.json();

                        if (result.success) {
                            if (result.saved) {
                                this.classList.add('active');
                                icon.classList.remove('bi-bookmark');
                                icon.classList.add('bi-bookmark-fill');
                                this.title = 'Remove bookmark';
                                // Micro-animation feedback
                                this.style.transform = 'scale(1.3)';
                                setTimeout(() => this.style.transform = '', 200);
                            } else {
                                this.classList.remove('active');
                                icon.classList.remove('bi-bookmark-fill');
                                icon.classList.add('bi-bookmark');
                                this.title = 'Save for later';
                            }
                        }
                    } catch (error) {
                        console.error('Error toggling bookmark:', error);
                    } finally {
                        this.disabled = false;
                    }
                });
            });
        });
    </script>
}
