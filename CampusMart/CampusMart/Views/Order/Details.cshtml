@model CampusMart.Models.ViewModels.User.OrderSummaryViewModel
@{
    ViewData["Title"] = "Receipt #" + Model.OrderId.ToString("D5");
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="cart-container">
    <div class="page-header animate-in">
        <a asp-controller="Order" asp-action="Index" class="back-btn">←</a>
        <div><h1 class="page-title">Receipt #@Model.OrderId.ToString("D5")</h1><p class="page-subtitle">Purchased on @Model.CreatedAt.ToString("MMMM dd, yyyy · h:mm tt")</p></div>
    </div>

    <!-- Order Status Banner -->
    <div class="order-status-banner animate-in d1">
        <div class="status-timeline">
            <div class="timeline-step completed">
                <div class="timeline-dot">✓</div>
                <div class="timeline-label">Ordered</div>
            </div>
            <div class="timeline-line completed"></div>
            <div class="timeline-step completed">
                <div class="timeline-dot">✓</div>
                <div class="timeline-label">Confirmed</div>
            </div>
            <div class="timeline-line @(Model.Status == "Completed" ? "completed" : "")"></div>
            <div class="timeline-step @(Model.Status == "Completed" ? "completed" : "")">
                <div class="timeline-dot">@(Model.Status == "Completed" ? "✓" : "○")</div>
                <div class="timeline-label">@(Model.Status == "Completed" ? "Completed" : "Pending")</div>
            </div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 340px;gap:28px;align-items:start;">
        <!-- Items -->
        <div>
            <div class="form-section animate-in d2">
                <div class="form-section-header">
                    <span class="form-section-icon">📦</span>
                    <h3 class="form-section-title">Items Purchased</h3>
                    <span class="form-section-desc">@Model.ItemCount items</span>
                </div>
                @foreach (var item in Model.Items)
                {
                    <div class="checkout-item">
                        <img src="@(item.ImageUrl ?? "https://via.placeholder.com/60")" alt="@item.ProductName" class="checkout-item-img">
                        <div class="checkout-item-info">
                            <div class="checkout-item-name">@item.ProductName</div>
                            <div class="checkout-item-meta">Qty: @item.Quantity × ₱@item.Price.ToString("F2")</div>
                        </div>
                        <div class="checkout-item-price">₱@((item.Price * item.Quantity).ToString("F2"))</div>
                    </div>
                }
            </div>

            <div class="form-section animate-in d3">
                <div class="form-section-header">
                    <span class="form-section-icon">📋</span>
                    <h3 class="form-section-title">Transaction Details</h3>
                </div>
                <div style="display:flex;gap:40px;flex-wrap:wrap;">
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;font-weight:600;margin-bottom:6px;">Fulfillment</div>
                        <div style="font-size:14px;color:#fff;">@(string.IsNullOrEmpty(Model.ShippingAddress) ? "To be arranged with seller" : Model.ShippingAddress)</div>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;font-weight:600;margin-bottom:6px;">Payment Method</div>
                        <div style="font-size:14px;color:#fff;">@(Model.PaymentMethod ?? "Cash")</div>
                    </div>
                    <div>
                        <div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;font-weight:600;margin-bottom:6px;">Status</div>
                        <div style="font-size:14px;color:var(--primary);font-weight:700;">@Model.Status</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Summary -->
        <div class="animate-in d3">
            <div class="form-section" style="position:sticky;top:100px;">
                <div class="form-section-header">
                    <span class="form-section-icon">🧾</span>
                    <h3 class="form-section-title">Payment Summary</h3>
                </div>
                <div class="cart-summary-row"><span>Subtotal</span><span>₱@Model.TotalAmount.ToString("N2")</span></div>
                <div class="cart-summary-row"><span>Platform Fee</span><span style="color:#4ade80;">Free</span></div>
                <div class="cart-summary-row total"><span>Total Paid</span><span>₱@Model.TotalAmount.ToString("N2")</span></div>

                <div style="margin-top:20px;padding:16px;background:rgba(74,222,128,.08);border:1px solid rgba(74,222,128,.2);border-radius:10px;text-align:center;">
                    <span style="font-size:20px;">✅</span>
                    <div style="font-size:14px;font-weight:700;color:#4ade80;margin-top:4px;">Purchase @Model.Status</div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                </div>

                <a asp-controller="UserDashboard" asp-action="Index" class="btn-checkout" style="display:block;text-align:center;text-decoration:none;margin-top:16px;">
                    Continue Shopping
                </a>
                <a asp-controller="Order" asp-action="Index" style="display:block;text-align:center;color:var(--text-muted);font-size:12px;margin-top:12px;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--text-muted)'">
                    View All Orders
                </a>
            </div>
        </div>
    </div>
</div>
