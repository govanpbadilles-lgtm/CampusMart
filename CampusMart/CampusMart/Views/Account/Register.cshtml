@model CampusMart.Models.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "CampusMart | Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
    <nav class="navbar-global">
        <a asp-controller="Home" asp-action="HomeIndex" class="navbar-brand">🛒 CampusMart</a>
        <a asp-controller="Home" asp-action="HomeIndex" class="back-link">← Back to Home</a>
    </nav>

    <div class="toast-global" id="toast"></div>

    <div class="auth-container auth-container--register">
        <div class="auth-card auth-card--register">
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle">Join the premium CampusMart community today</p>

            <form asp-action="Register" asp-controller="Account" method="post" autocomplete="off" onsubmit="return validatePasswords(event)">
                <div asp-validation-summary="ModelOnly" class="validation-error" style="margin-bottom: 15px; color: #ff8f8f; text-align: center;"></div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName">First Name</label>
                        <input asp-for="FirstName" class="input-glass" placeholder="Juan" autocomplete="off" required>
                        <span asp-validation-for="FirstName" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="LastName">Last Name</label>
                        <input asp-for="LastName" class="input-glass" placeholder="Dela Cruz" autocomplete="off" required>
                        <span asp-validation-for="LastName" class="validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="StudentId">Student ID Number</label>
                    <input asp-for="StudentId" class="input-glass" placeholder="e.g. 2024-12345" autocomplete="off" required>
                    <span class="help-text">Your official university-issued ID number</span>
                    <span asp-validation-for="StudentId" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email" type="email" class="input-glass" placeholder="juan@university.edu.ph" autocomplete="off" required>
                    <span asp-validation-for="Email" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Department">Department / College</label>
                    <select asp-for="Department" class="input-glass" required>
                        <option value="" disabled selected>Select your department</option>
                        <option value="College of Information Technology">College of Information Technology</option>
                        <option value="College of Engineering">College of Engineering</option>
                        <option value="College of Business">College of Business</option>
                        <option value="College of Education">College of Education</option>
                        <option value="College of Arts &amp; Sciences">College of Arts &amp; Sciences</option>
                        <option value="College of Nursing">College of Nursing</option>
                        <option value="Graduate School">Graduate School</option>
                    </select>
                    <span asp-validation-for="Department" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Create Password</label>
                    <div class="password-group">
                        <input asp-for="Password" class="input-glass" placeholder="At least 8 characters" minlength="8" autocomplete="off" required>
                        <button type="button" class="toggle-password" onclick="togglePassword('Password', this)" tabindex="-1" title="Toggle password visibility">
                            <svg id="eyeIcon-Password" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <div class="password-group">
                        <input asp-for="ConfirmPassword" class="input-glass" placeholder="Re-enter password" autocomplete="off" required>
                        <button type="button" class="toggle-password" onclick="togglePassword('ConfirmPassword', this)" tabindex="-1" title="Toggle password visibility">
                            <svg id="eyeIcon-ConfirmPassword" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        </button>
                    </div>
                    <span class="password-match-error" id="passwordMatchError">Passwords do not match.</span>
                    <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
                </div>

                <button type="submit" class="btn-submit btn-submit--register">Create Account →</button>

                <div class="auth-link">
                    Already have an account? <a asp-action="Login" asp-controller="Account">Sign in here</a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const eyeOpenSvg = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>`;
        const eyeClosedSvg = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3l18 18m0 0L3 3m18 0l-18 18M10.477 10.477A3 3 0 0113.5 13.5M6.357 6.357A9.965 9.965 0 012.458 12c1.274 4.057 5.065 7 9.542 7a9.966 9.966 0 005.643-1.745"/></svg>`;

        function togglePassword(fieldId, button) {
            const input = document.querySelector(`input[name="${fieldId}"]`);
            const icon = button.querySelector('svg');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.outerHTML = eyeClosedSvg;
            } else {
                input.type = 'password';
                icon.outerHTML = eyeOpenSvg;
            }
        }

        function validatePasswords(e) {
            const password = document.querySelector('input[name="Password"]');
            const confirmPassword = document.querySelector('input[name="ConfirmPassword"]');
            const errorMsg = document.getElementById('passwordMatchError');

            if (password.value !== confirmPassword.value) {
                e.preventDefault();
                errorMsg.classList.add('show');
                confirmPassword.focus();
                return false;
            } else {
                errorMsg.classList.remove('show');
            }
            return true;
        }

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const icon = type === 'success' ? '✅' : '❌';
            toast.innerHTML = `${icon} ${message}`;
            
            if (type === 'error') {
                toast.style.background = 'rgba(239, 68, 68, 0.95)';
            } else {
                toast.style.background = 'rgba(34, 197, 94, 0.95)';
            }
            
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 4000);
        }

        // Real-time password match validation
        document.querySelector('input[name="ConfirmPassword"]').addEventListener('input', function() {
            const password = document.querySelector('input[name="Password"]').value;
            const errorMsg = document.getElementById('passwordMatchError');
            
            if (this.value && this.value !== password) {
                errorMsg.classList.add('show');
            } else {
                errorMsg.classList.remove('show');
            }
        });

        // Clear input values on page load
        window.addEventListener('load', () => {
            document.querySelectorAll('input[type="text"], input[type="password"], input[type="email"]').forEach(el => {
                el.value = '';
            });

            @if (TempData["SuccessMessage"] != null)
            {
                <text>showToast('@TempData["SuccessMessage"]', 'success');</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>showToast('@TempData["ErrorMessage"]', 'error');</text>
            }
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
