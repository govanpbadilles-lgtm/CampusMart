@model CampusMart.Models.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "CampusMart | Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>
<body>
    <nav class="navbar-global">
        <a asp-controller="Home" asp-action="HomeIndex" class="navbar-brand"><i class="bi bi-shop"></i> CampusMart</a>
        <a asp-controller="Home" asp-action="HomeIndex" class="back-link"><i class="bi bi-arrow-left"></i> Back to Home</a>
    </nav>

    <div class="auth-container auth-container--register">
        <div class="auth-card auth-card--register">
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle">Join the premium CampusMart community today</p>

            <form asp-action="Register" asp-controller="Account" method="post" autocomplete="off" onsubmit="return validatePasswords(event)">
                <div asp-validation-summary="ModelOnly" class="validation-error" style="margin-bottom: 15px; color: #ff8f8f; text-align: center;"></div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName"><i class="bi bi-person"></i> First Name</label>
                        <input asp-for="FirstName" class="input-glass" placeholder="Juan" autocomplete="off" required>
                        <span asp-validation-for="FirstName" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="LastName"><i class="bi bi-person"></i> Last Name</label>
                        <input asp-for="LastName" class="input-glass" placeholder="Dela Cruz" autocomplete="off" required>
                        <span asp-validation-for="LastName" class="validation-error"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="StudentId"><i class="bi bi-person-id-card"></i> Student ID Number</label>
                        <input asp-for="StudentId" class="input-glass" placeholder="e.g. 2024-12345" autocomplete="off" required>
                        <span asp-validation-for="StudentId" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email"><i class="bi bi-envelope"></i> Email Address</label>
                        <input asp-for="Email" type="email" class="input-glass" placeholder="juan@university.edu.ph" autocomplete="off" required>
                        <span asp-validation-for="Email" class="validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Department"><i class="bi bi-building"></i> Department / College</label>
                    <select asp-for="Department" class="input-glass" required>
                        <option value="" disabled selected>Select your department</option>
                        <option value="College of Information Technology">College of Information Technology</option>
                        <option value="College of Engineering">College of Engineering</option>
                        <option value="College of Business">College of Business</option>
                        <option value="College of Education">College of Education</option>
                        <option value="College of Arts &amp; Sciences">College of Arts &amp; Sciences</option>
                        <option value="College of Nursing">College of Nursing</option>
                        <option value="Graduate School">Graduate School</option>
                    </select>
                    <span asp-validation-for="Department" class="validation-error"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Password"><i class="bi bi-lock-fill"></i> Create Password</label>
                        <div class="password-group">
                            <input asp-for="Password" class="input-glass" placeholder="At least 8 characters" minlength="8" autocomplete="off" required oninput="checkPasswordStrength()">
                            <button type="button" class="toggle-password" onclick="togglePassword('Password', this)" tabindex="-1" title="Toggle password visibility">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                        <div class="password-strength-wrapper" id="strengthWrapper">
                            <div class="password-strength-header">
                                <span class="strength-label">Security Level</span>
                                <span id="strengthText">None</span>
                            </div>
                            <div class="password-strength-container">
                                <div class="password-strength-bar" id="strengthBar"></div>
                            </div>
                        </div>
                        <span asp-validation-for="Password" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword"><i class="bi bi-lock-fill"></i> Confirm Password</label>
                        <div class="password-group">
                            <input asp-for="ConfirmPassword" class="input-glass" placeholder="Re-enter password" autocomplete="off" required>
                            <button type="button" class="toggle-password" onclick="togglePassword('ConfirmPassword', this)" tabindex="-1" title="Toggle password visibility">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                        <span class="password-match-error" id="passwordMatchError">Passwords do not match.</span>
                        <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-submit btn-submit--register"><i class="bi bi-person-plus-fill"></i> Create Account</button>

                <div class="auth-link">
                    Already have an account? <a asp-action="Login" asp-controller="Account">Sign in here</a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        function showToast(message, type = 'success') {
            Toast.fire({
                icon: type,
                title: message
            });
        }

        function togglePassword(fieldId, button) {
            const input = document.querySelector(`input[name="${fieldId}"]`);
            const icon = button.querySelector('i');

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye-fill');
                icon.classList.add('bi-eye-slash-fill');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash-fill');
                icon.classList.add('bi-eye-fill');
            }
        }

        function validatePasswords(event) {
            const password = document.querySelector('input[name="Password"]').value;
            const confirmPassword = document.querySelector('input[name="ConfirmPassword"]').value;
            const errorElement = document.getElementById('passwordMatchError');

            if (password !== confirmPassword) {
                errorElement.style.display = 'block';
                event.preventDefault();
                return false;
            }
            errorElement.style.display = 'none';
            return true;
        }

        function checkPasswordStrength() {
            const password = document.querySelector('input[name="Password"]').value;
            const wrapper = document.getElementById('strengthWrapper');
            const bar = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');

            if (password.length === 0) {
                wrapper.classList.remove('show');
                return;
            }

            wrapper.classList.add('show');
            let strength = 0;
            
            // Criteria
            if (password.length >= 8) strength += 20;
            if (/[A-Z]/.test(password)) strength += 20;
            if (/[a-z]/.test(password)) strength += 20;
            if (/[0-9]/.test(password)) strength += 20;
            if (/[^A-Za-z0-9]/.test(password)) strength += 20;

            // Reset classes
            bar.classList.remove('bg-weak', 'bg-medium', 'bg-strong');
            text.classList.remove('strength-weak', 'strength-medium', 'strength-strong');

            bar.style.width = strength + '%';

            if (strength <= 40) {
                text.innerText = "Weak Password";
                text.classList.add('strength-weak');
                bar.classList.add('bg-weak');
            } else if (strength <= 80) {
                text.innerText = "Medium Password";
                text.classList.add('strength-medium');
                bar.classList.add('bg-medium');
            } else {
                text.innerText = "Strong Password";
                text.classList.add('strength-strong');
                bar.classList.add('bg-strong');
            }
        }

        window.addEventListener('load', () => {
            @if (TempData["SuccessMessage"] != null)
            {
                <text>showToast('@TempData["SuccessMessage"]', 'success');</text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>showToast('@TempData["ErrorMessage"]', 'error');</text>
            }
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
