@{
    ViewData["Title"] = "CampusMart | Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
    <nav class="navbar-global">
        <a asp-controller="Home" asp-action="HomeIndex" class="navbar-brand"><i class="bi bi-shop"></i> CampusMart</a>
        <a asp-controller="Account" asp-action="Login" class="back-link"><i class="bi bi-arrow-left"></i> Back to Login</a>
    </nav>

    <div class="toast-global" id="toast"></div>

    <div class="auth-container">
        <div class="auth-card">
            <h1 class="auth-title">Verify Identity</h1>
            <p class="auth-subtitle">Enter your Student ID and registered Email to reset your password.</p>

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" autocomplete="off">
                <div asp-validation-summary="ModelOnly" class="validation-error" style="margin-bottom: 15px; color: #ff8f8f; text-align: center;"></div>
                
                <div class="form-group">
                    <label for="studentId">Student ID Number</label>
                    <input type="text" id="studentId" name="studentId" class="input-glass" placeholder="e.g. 2024-12345" autocomplete="off" required>
                </div>

                <div class="form-group">
                    <label for="email">Registered Email</label>
                    <input type="email" id="email" name="email" class="input-glass" placeholder="juan@university.edu.ph" autocomplete="off" required>
                </div>

                <button type="submit" class="btn-submit">Verify Account →</button>

                <div class="auth-link">
                    Remember your password? <a asp-action="Login" asp-controller="Account">Sign in here</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
