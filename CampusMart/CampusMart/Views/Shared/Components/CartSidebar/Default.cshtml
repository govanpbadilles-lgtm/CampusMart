@model CampusMart.Models.ViewModels.User.CartViewModel

<div class="notification-header">
    <div>
        <h2 class="fs-5 fw-800 text-white mb-0"><i class="bi bi-cart3 text-warning"></i> Your cart</h2>
        <p class="x-small text-white-50 mb-0">Same cart as <strong class="text-white">My cart</strong>—line totals include quantity.</p>
    </div>
    <button class="close-modal" id="closeCartBtn" type="button">&times;</button>
</div>
<div class="notification-body p-4 d-flex flex-column" style="height: calc(100vh - 90px); overflow-y: auto;">
    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="empty-state text-center py-5 opacity-50 my-auto">
            <i class="bi bi-cart-x fs-1 mb-3 d-block text-white-50"></i>
            <p class="small text-white-50">Your cart is empty.</p>
        </div>
    }
    else
    {
        <div class="flex-grow-1">
            @foreach (var item in Model.Items)
            {
                var lineTotal = item.Price * item.Quantity;
                <div class="d-flex align-items-center gap-3 mb-3 p-3 glass-card rounded-3">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                    }
                    else
                    {
                        <div class="bg-dark d-flex align-items-center justify-content-center text-white-50" style="width: 60px; height: 60px; border-radius: 8px;">
                            <i class="bi bi-box"></i>
                        </div>
                    }
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-700 text-white fs-6 text-truncate" style="max-width: 160px;">@item.ProductName</div>
                        <div class="x-small text-white-50">Qty @item.Quantity · ₱@item.Price.ToString("N2") ea</div>
                    </div>
                    <div class="fw-800 text-warning text-nowrap">
                        ₱@lineTotal.ToString("N2")
                    </div>
                </div>
            }
        </div>

        <div class="mt-4 pt-4 border-top border-secondary border-opacity-25">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="text-white-50 fw-600">Subtotal</span>
                <span class="fs-5 fw-800 text-white">₱@Model.Total.ToString("N2")</span>
            </div>
            <a asp-controller="Order" asp-action="Checkout" class="cm-btn-primary w-100 py-3 justify-content-center mb-2">Proceed to checkout</a>
            <a asp-controller="Cart" asp-action="Index" class="cm-btn-outline w-100 py-2 justify-content-center border-0 text-white">Open full cart</a>
        </div>
    }
</div>
