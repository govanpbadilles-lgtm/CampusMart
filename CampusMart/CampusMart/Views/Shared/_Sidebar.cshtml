@{
    var adminId = User.Identity?.IsAuthenticated == true ? (User.Identity!.Name ?? "Admin") : "Admin";
    var adminDisplayName = string.IsNullOrWhiteSpace(adminId) ? "Admin" : adminId;
    var avatarUrl = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(adminDisplayName)}&background=222&color=fff";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var isProductAreaPage = currentController.Equals("Dashboard", StringComparison.OrdinalIgnoreCase)
        || currentController.Equals("Product", StringComparison.OrdinalIgnoreCase);
}

<aside class="sidebar" aria-label="Admin sidebar">
    <div class="sidebar-header">
        <a href="#" class="sidebar-brand">CAMPUSELITE</a>
    </div>

    <div class="portal-title">
        <h3>Admin Portal</h3>
        <p>Elite Concierge Service</p>
    </div>

    <nav class="sidebar-nav" id="sidebarNav">
        <a asp-area="Admin" asp-controller="Product" asp-action="Index"
           class="nav-item @(isProductAreaPage ? "active" : "")" data-target="postListingSection">
            <span class="nav-icon">➕</span> Post Listing
        </a>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index"
           class="nav-item" data-target="activeListingsSection">
            <span class="nav-icon">📦</span> My Active Listings
        </a>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="nav-item">
            <span class="nav-icon">📈</span> Analytics
        </a>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="nav-item">
            <span class="nav-icon">💳</span> Payouts
        </a>
    </nav>

    <div class="user-profile profile-trigger" id="userProfileBtn" role="button" tabindex="0">
        <img src="@avatarUrl" alt="@adminDisplayName" class="user-avatar" id="sidebarAvatar" />
        <div class="user-info">
            <h3 id="sidebarName">@adminDisplayName</h3>
            <p>Admin</p>
        </div>
    </div>
</aside>
