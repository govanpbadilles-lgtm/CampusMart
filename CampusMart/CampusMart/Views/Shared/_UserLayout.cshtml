@using Microsoft.AspNetCore.Identity
@using CampusMart.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    var appUser = await UserManager.GetUserAsync(User);
    var userName = appUser?.FullName ?? (User.Identity?.Name ?? "Guest");
    var avatarUrl = appUser?.AvatarUrl ?? $"https://ui-avatars.com/api/?name={userName}&background=222&color=fff";
    var studentId = appUser?.StudentId ?? "";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CampusMart</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user-pages.css" asp-append-version="true" />
</head>
<body class="user-body-elite@(ViewData["UserBodyExtraClass"] != null ? " " + ViewData["UserBodyExtraClass"] : "")">

    <!-- TOP NAV -->
    <header class="cm-navbar elite-topbar sticky-top">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between h-100">
                <div class="topbar-left d-flex align-items-center gap-3">
                    <button id="sidebarToggleBtn" class="mobile-toggle-btn d-lg-none">
                        <i class="bi bi-list"></i>
                    </button>
                    <a asp-controller="UserDashboard" asp-action="Index" class="navbar-brand cm-brand">
                        <div class="brand-logo-hex"><i class="bi bi-shop"></i></div>
                        <span class="d-none d-sm-inline">CampusMart</span>
                    </a>
                </div>

                <div class="topbar-right d-flex align-items-center gap-3">
                    <button id="cartToggleBtn" class="nav-icon-link" title="Shopping Cart">
                        <i class="bi bi-bag-fill"></i>
                    </button>
                    <button id="notificationToggleBtn" class="nav-icon-link" title="Notifications">
                        <i class="bi bi-bell-fill"></i>
                        <span class="notify-dot"></span>
                    </button>
                    <div class="vr mx-2 opacity-10"></div>
                    <div class="dropdown">
                        <a href="#" class="nav-profile-trigger" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="@avatarUrl" alt="Avatar" class="nav-avatar" id="sidebarAvatar" />
                            <div class="nav-user-info d-none d-md-flex">
                                <span class="nav-user-name" id="sidebarName">@userName</span>
                                <span class="nav-user-role">Student @studentId</span>
                            </div>
                            <i class="bi bi-chevron-down ms-1"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end cm-dropdown shadow-lg" aria-labelledby="userDropdown">
                            <li><h6 class="dropdown-header">Fast Access</h6></li>
                            <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-circle"></i> View Profile</a></li>
                            <li><a class="dropdown-item" asp-controller="Order" asp-action="History"><i class="bi bi-clock-history"></i> My Orders</a></li>
                            <li><hr class="dropdown-divider opacity-10"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger fw-700"><i class="bi bi-power"></i> Sign Out</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="elite-wrapper">
        <!-- SIDEBAR -->
        <aside class="elite-sidebar" id="mainSidebar">
            <!-- Mobile Close Button -->
            <button class="sidebar-close-btn d-lg-none" id="closeSidebarBtn" type="button" aria-label="Close sidebar">
                <i class="bi bi-x-lg"></i>
            </button>
            <div class="sidebar-content">
                <nav class="sidebar-nav-group">
                    <div class="nav-label">Main</div>
                    <a asp-controller="UserDashboard" asp-action="Index"
                       class="nav-link-elite @(currentController == "UserDashboard" && currentAction == "Index" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> <span>Dashboard</span>
                    </a>

                    <div class="nav-label mt-4">Marketplace</div>
                    <a asp-controller="Cart" asp-action="Index"
                       class="nav-link-elite @(currentController == "Cart" ? "active" : "")">
                        <i class="bi bi-cart4"></i> <span>My Cart</span>
                    </a>
                    <a asp-controller="UserDashboard" asp-action="Saved"
                       class="nav-link-elite @(currentController == "UserDashboard" && currentAction == "Saved" ? "active" : "")">
                        <i class="bi bi-heart-fill"></i> <span>Saved Items</span>
                    </a>
                    <a asp-controller="Order" asp-action="History"
                       class="nav-link-elite @(currentController == "Order" ? "active" : "")">
                        <i class="bi bi-clock-history"></i> <span>Purchase History</span>
                    </a>
                </nav>
            </div>

            <div class="sidebar-footer-elite">
                <a asp-controller="Profile" asp-action="Index" class="footer-action-link">
                    <i class="bi bi-person-gear"></i> <span>Account Settings</span>
                </a>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="elite-main">
            <div class="content-container">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- CART SIDEBAR -->
    <div class="cart-sidebar-wrapper" id="cartSidebar">
        @await Component.InvokeAsync("CartSidebar")
    </div>

    <!-- NOTIFICATION SIDEBAR -->
    <div class="notification-sidebar-wrapper" id="notificationSidebar">
        <div class="notification-header">
            <div>
                <h2 class="fs-5 fw-800 text-white mb-0"><i class="bi bi-bell-fill text-warning"></i> System Alerts</h2>
                <p class="x-small text-muted mb-0">Real-time campus updates</p>
            </div>
            <button class="close-modal" id="closeNotificationBtn">&times;</button>
        </div>
        <div class="notification-body p-4">
            <div class="empty-state text-center py-5 opacity-50">
                <i class="bi bi-bell-slash fs-1 mb-3 d-block"></i>
                <p class="small">No new notifications</p>
            </div>
        </div>
    </div>

    <!-- OVERLAY -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- PROFILE MODAL -->
    <div class="modal-overlay" id="profileModal">
        <div class="profile-modal elite-profile-popup">
            <div class="modal-header">
                <div>
                    <h2 class="modal-title">Student Profile</h2>
                    <p class="modal-subtitle text-muted small">Update your portal display identity</p>
                </div>
                <button class="close-modal" id="closeProfileModal" type="button">&times;</button>
            </div>
            <form id="quickEditForm" enctype="multipart/form-data">
                <div class="profile-pic-edit-container mb-4">
                    <div class="pic-wrapper">
                        <img src="@avatarUrl" alt="Profile" class="profile-pic-preview" id="modalPicPreview" />
                        <button class="pic-edit-overlay" type="button" onclick="document.getElementById('profilePicInput').click()">
                            <i class="bi bi-camera-fill"></i>
                        </button>
                    </div>
                    <div class="pic-meta">
                        <span class="admin-status-pill"><i class="bi bi-person-check-fill"></i> Verified Student</span>
                        <p class="pic-info small text-muted">Upload an image</p>
                    </div>
                    <input type="file" id="profilePicInput" name="avatarFile" style="display: none;" accept="image/*" />
                </div>

                <div class="form-group-elite mb-3">
                    <label class="modal-label"><i class="bi bi-person-fill text-warning"></i> Full Name</label>
                    <input type="text" class="modal-input" id="profileNameInput" name="fullName" value="@userName" placeholder="Enter your full name" required />
                </div>

                <div class="form-group-elite mb-4">
                    <label class="modal-label"><i class="bi bi-person-badge-fill text-warning"></i> Student ID</label>
                    <div class="input-group-elite">
                        <input type="text" class="modal-input opacity-50" value="@studentId" readonly />
                        <i class="bi bi-lock-fill position-absolute end-0 me-3 text-muted"></i>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <button class="cm-btn-outline w-100 py-3" type="button" onclick="document.getElementById('profileModal').classList.remove('active'); document.getElementById('sidebarOverlay').classList.remove('active');">Cancel</button>
                    <button class="cm-btn-primary w-100 py-3 justify-content-center" id="saveProfileBtn" type="submit">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/user.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_ToastNotifications")
    <script>
        @if (TempData["OpenCart"] != null)
        {
            <text>
            document.addEventListener("DOMContentLoaded", function() {
                var cartSidebar = document.getElementById("cartSidebar");
                var sidebarOverlay = document.getElementById("sidebarOverlay");
                if (cartSidebar) cartSidebar.classList.add("open");
                if (sidebarOverlay) sidebarOverlay.classList.add("active");
                document.body.style.overflow = "hidden";
            });
            </text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
