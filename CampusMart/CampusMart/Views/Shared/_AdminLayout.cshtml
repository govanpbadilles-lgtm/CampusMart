@using Microsoft.AspNetCore.Identity
@using CampusMart.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    var appUser = await UserManager.GetUserAsync(User);
    var adminDisplayName = appUser?.FullName ?? (User.Identity?.Name ?? "Admin");
    var avatarUrl = appUser?.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(adminDisplayName)}&background=222&color=fff";
    var adminId = appUser?.StudentId ?? (User.Identity?.Name ?? "Admin");
    ViewData["Title"] ??= "Admin";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CampusMart</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    @await Html.PartialAsync("~/Views/Shared/_AdminSidebar.cshtml")

    <main class="admin-main">
        <header class="topbar">
            <div class="topbar-left">
                <button id="adminSidebarToggle" class="mobile-toggle-btn d-lg-none">
                    <i class="bi bi-list"></i>
                </button>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="mobile-brand d-lg-none">
                    <i class="bi bi-shield-lock-fill"></i>
                </a>
                <div class="breadcrumb-area">
                    <h1 id="pageTitle">@ViewData["Title"]</h1>
                </div>
            </div>
            <div class="top-tools">
                <a href="javascript:void(0)" id="notificationBtn" class="tool-btn" title="Notifications">
                    <i class="bi bi-bell-fill"></i>
                    <span class="notification-badge" style="display:none;" id="navNotifyBadge">0</span>
                </a>
            </div>
        </header>

        <div class="content-wrap">
            @RenderBody()
        </div>
    </main>

    <!-- MODERN PROFILE MODAL -->
    <div class="modal-overlay" id="profileModal">
        <div class="profile-modal elite-profile-popup">
            <div class="modal-header">
                <div>
                    <h2 class="modal-title">Admin Account</h2>
                    <p class="modal-subtitle">Elite Administrative Credentials</p>
                </div>
                <button class="close-modal" id="closeProfileModal" type="button">&times;</button>
            </div>

            <form id="adminQuickEditForm" enctype="multipart/form-data">
                <div class="profile-pic-edit-container">
                    <div class="pic-wrapper">
                        <img src="@avatarUrl" alt="Profile" class="profile-pic-preview" id="modalPicPreview" />
                        <button class="pic-edit-overlay" type="button" id="changeProfilePicBtn">
                            <i class="bi bi-camera-fill"></i>
                        </button>
                    </div>
                    <div class="pic-meta">
                        <span class="admin-status-pill"><i class="bi bi-shield-check"></i> Verified Admin</span>
                        <img id="adminSmallPreview" style="width: 24px; height: 24px; border-radius: 4px; border: 1px solid var(--admin-primary); object-fit: cover; display: none; margin: 8px 0;" />
                        <p class="pic-info">Upload an image</p>
                    </div>
                    <input type="file" id="profilePicInput" name="avatarFile" style="display: none;" accept="image/*" />
                </div>

                <div class="profile-form-grid">
                    <div class="modal-form-group">
                        <label class="modal-label"><i class="bi bi-person-fill"></i> Full Identity</label>
                        <input type="text" class="modal-input" id="profileNameInput" name="fullName" value="@adminDisplayName" placeholder="Full Name" required />
                    </div>

                    <div class="modal-form-group">
                        <label class="modal-label"><i class="bi bi-envelope-at-fill"></i> System Email</label>
                        <input type="email" class="modal-input" name="email" value="@appUser?.Email" placeholder="admin@campusmart.local" />
                    </div>

                    <div class="modal-form-group">
                        <label class="modal-label"><i class="bi bi-phone-fill"></i> Direct Contact</label>
                        <input type="text" class="modal-input" name="phoneNumber" value="@appUser?.PhoneNumber" placeholder="+63 9XX XXX XXXX" />
                    </div>

                    <div class="modal-form-group">
                        <label class="modal-label"><i class="bi bi-building-fill"></i> Department</label>
                        <div class="modal-input-readonly-container">
                            <input type="text" class="modal-input" value="@(appUser?.Department ?? "Administration")" readonly />
                            <i class="bi bi-lock-fill input-icon"></i>
                        </div>
                    </div>
                </div>

                <div class="modal-form-group full-span">
                    <label class="modal-label"><i class="bi bi-key-fill"></i> Administrative ID</label>
                    <div class="modal-input-readonly-container">
                        <input type="text" class="modal-input" value="@adminId" readonly />
                        <i class="bi bi-lock-fill input-icon"></i>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <button class="cm-btn-outline w-100" type="button" onclick="closeModal('profileModal')">Cancel</button>
                    <button class="cm-btn-primary w-100" id="saveProfileBtn" type="submit">
                        <i class="bi bi-cloud-arrow-up-fill"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- NOTIFICATION SIDEBAR -->
    <div class="notification-sidebar" id="notificationSidebar">
        <div class="notification-sidebar-header">
            <div>
                <h3 class="notification-title">Notifications</h3>
                <p class="notification-subtitle">Real-time system alerts and updates</p>
            </div>
            <button class="notification-close" id="closeNotificationSidebar">&times;</button>
        </div>
        <div class="notification-actions">
            <button class="mark-read-btn" id="markAllReadBtn">
                <i class="bi bi-check-all"></i> Mark all as read
            </button>
        </div>
        <div class="notification-list" id="notificationList">
            <!-- Notifications loaded via JS -->
            <div class="notification-loading">
                <i class="bi bi-arrow-clockwise spin"></i> Loading...
            </div>
        </div>
    </div>

    <!-- NOTIFICATION OVERLAY -->
    <div class="notification-overlay" id="notificationOverlay"></div>

    <!-- SIDEBAR OVERLAY FOR MOBILE -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_ToastNotifications")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
