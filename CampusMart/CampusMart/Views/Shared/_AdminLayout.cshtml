@using Microsoft.AspNetCore.Identity
@using CampusMart.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    var appUser = await UserManager.GetUserAsync(User);
    var adminDisplayName = appUser?.FullName ?? (User.Identity?.Name ?? "Admin");
    var avatarUrl = appUser?.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(adminDisplayName)}&background=222&color=fff";
    var adminId = appUser?.StudentId ?? (User.Identity?.Name ?? "Admin");
    ViewData["Title"] ??= "Admin";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CampusMart</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user-sell-profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    @* Sidebar (separated for readability) *@
    @await Html.PartialAsync("~/Views/Shared/_AdminSidebar.cshtml")

    <main class="admin-main">
        <header class="topbar">
            <h1 id="pageTitle">@ViewData["Title"]</h1>
            <div class="top-tools">
                <input class="search" type="text" placeholder="Search stalls, owners...">
                <a asp-area="Admin" asp-controller="Notification" asp-action="Index" class="icon-btn" style="text-decoration:none;" aria-label="Notifications">🔔</a>
                <button class="icon-btn profile-trigger" id="topProfileBtn" type="button" aria-label="Open profile editor">👤</button>
            </div>
        </header>

        <div class="content-wrap">
            @RenderBody()
        </div>
    </main>

    <!-- PROFILE EDIT MODAL -->
    <div class="modal-overlay" id="profileModal">
        <div class="profile-modal">
            <div class="modal-header">
                <h2 class="modal-title">Edit Profile</h2>
                <button class="close-modal" id="closeProfileModal" type="button">&times;</button>
            </div>

            <form id="adminQuickEditForm" enctype="multipart/form-data">
                <div class="profile-pic-edit">
                    <img src="@avatarUrl" alt="Profile" class="profile-pic-preview" id="modalPicPreview" />
                    <button class="btn-outline" type="button" id="changeProfilePicBtn">Change Picture</button>
                    <input type="file" id="profilePicInput" name="avatarFile" style="display: none;" accept="image/*" />
                </div>

                <div class="modal-form-group">
                    <label class="modal-label" for="profileNameInput">Full Name</label>
                    <input type="text" class="modal-input" id="profileNameInput" name="fullName" value="@adminDisplayName" required />
                </div>

                <div class="modal-form-group">
                    <label class="modal-label" for="profileIdInput">ID Number</label>
                    <input type="text" class="modal-input" id="profileIdInput" value="@adminId" readonly style="background: rgba(255,255,255,0.05); color: var(--text-muted);" />
                </div>

                <div class="modal-form-group">
                    <label class="modal-label" for="profileCourseInput">Course</label>
                    <input type="text" class="modal-input" id="profileCourseInput" value="Admin Portal" readonly style="background: rgba(255,255,255,0.05); color: var(--text-muted);" />
                </div>

                <button class="btn-save" id="saveProfileBtn" type="submit">Save Changes</button>
            </form>
        </div>
    </div>

    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
