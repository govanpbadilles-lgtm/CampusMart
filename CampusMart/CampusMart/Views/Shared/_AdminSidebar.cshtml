@using Microsoft.AspNetCore.Identity
@using CampusMart.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    var appUser = await UserManager.GetUserAsync(User);
    var adminDisplayName = appUser?.FullName ?? (User.Identity?.Name ?? "Admin");
    var avatarUrl = appUser?.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(adminDisplayName)}&background=222&color=fff";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<aside class="admin-sidebar" style="height:100vh;display:flex;flex-direction:column;">
    <div style="padding:18px;border-bottom:1px solid rgba(255,255,255,0.08);">
        <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;border-radius:10px;background:var(--primary);color:#111;display:flex;align-items:center;justify-content:center;font-weight:900;">C</div>
            <div>
                <div style="font-size:28px;font-weight:800;color:#ffd54f;">CampusMart</div>
                <div style="font-size:12px;color:#b9bfcb;">Elite Admin Suite</div>
            </div>
        </div>
    </div>

    <nav style="padding:12px;display:flex;flex-direction:column;gap:4px;">
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" 
           class="admin-nav @(currentController.Equals("Dashboard", StringComparison.OrdinalIgnoreCase) && currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
            🟨 Floor Management
        </a>
        <a asp-area="Admin" asp-controller="Listing" asp-action="Index" 
           class="admin-nav @(currentController.Equals("Listing", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
            📝 Listing
        </a>
        <a asp-area="Admin" asp-controller="Rental" asp-action="Index" 
           class="admin-nav @(currentController.Equals("Rental", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
            🏷️ Rentals
        </a>
        <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index" 
           class="admin-nav @(currentController.Equals("UserManagement", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
            👥 Student Directory
        </a>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" 
           class="admin-nav @(currentController.Equals("Order", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
            📈 Store Oversight
        </a>
        <a asp-area="Admin" asp-controller="Academic" asp-action="Index" 
           class="admin-nav @(currentController.Equals("Academic", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
            📚 Academic Needs
        </a>
        <a asp-area="Admin" asp-controller="Settings" asp-action="Index" 
           class="admin-nav @(currentController.Equals("Settings", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
            ⚙️ Settings
        </a>
    </nav>

    <div style="margin-top:auto;padding:14px;border-top:1px solid rgba(255,255,255,0.08); display:flex; flex-direction:column; gap:12px;">
        <button class="btn profile-trigger" style="width:100%; display: flex; align-items: center; justify-content: center; gap: 8px;">
            <img src="@avatarUrl" alt="Avatar" id="sidebarAvatar" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;" /> 
            <span id="sidebarName">@adminDisplayName</span>
        </button>
        
        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" style="width: 100%;">
            <button type="submit" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; padding: 10px; color: #ef4444; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;" onmouseover="this.style.background='rgba(239, 68, 68, 0.2)'" onmouseout="this.style.background='rgba(239, 68, 68, 0.1)'">
                <span>🚪</span> Logout
            </button>
        </form>
    </div>
</aside>
