@using Microsoft.AspNetCore.Identity
@using CampusMart.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    var appUser = await UserManager.GetUserAsync(User);
    var adminDisplayName = appUser?.FullName ?? (User.Identity?.Name ?? "Admin");
    var avatarUrl = appUser?.AvatarUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(adminDisplayName)}&background=222&color=fff";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<aside class="admin-sidebar">
    <div class="sidebar-branding">
        <div class="brand-logo">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div class="brand-text">
            <div class="brand-name">CampusMart</div>
            <div class="brand-sub">Admin Dashboard</div>
        </div>
    </div>

    <div class="admin-nav-group">
        <div class="nav-group-label">Core Management</div>
        
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" 
           class="admin-nav @(currentController == "Dashboard" ? "active" : "")">
            <span><i class="bi bi-grid-1x2-fill"></i></span> Floor & Stalls
        </a>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" 
           class="admin-nav @(currentController == "Order" ? "active" : "")">
            <span><i class="bi bi-shop"></i></span> Store Oversight
        </a>
        <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index" 
           class="admin-nav @(currentController == "UserManagement" ? "active" : "")">
            <span><i class="bi bi-people-fill"></i></span> Student Directory
        </a>
        
        <div class="nav-group-label">Configuration</div>
        
        <a asp-area="Admin" asp-controller="Settings" asp-action="Index" 
           class="admin-nav @(currentController == "Settings" ? "active" : "")">
            <span><i class="bi bi-sliders"></i></span> System Settings
        </a>
    </div>

    <div class="sidebar-footer">
        <div class="sidebar-profile-card profile-trigger" title="Edit Profile">
            <img src="@avatarUrl" alt="Avatar" id="sidebarAvatar" style="width: 36px; height: 36px; border-radius: 10px; object-fit: cover; border: 1px solid rgba(255,255,255,0.1);" /> 
            <div class="info-wrap">
                <span id="sidebarName" class="admin-name">@adminDisplayName</span>
                <span class="role-tag">Administrator</span>
            </div>
            <i class="bi bi-gear-fill" style="color: var(--text-dim); font-size: 14px;"></i>
        </div>
        
        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0" style="width: 100%;">
            <button type="submit" class="admin-logout-btn">
                <i class="bi bi-door-open-fill"></i> 
                <span>Logout Session</span>
            </button>
        </form>
    </div>
</aside>
