@{
    ViewData["Title"] = "Contact";
}

<section class="hero animate-fade-in"> 
    <div class="tag">Get In Touch</div> 
    <h1>Contact CampusMart</h1> 
    <p>Have questions, feedback, or need support? We're here to help you make the most of your campus experience.</p> 
</section>

<section class="section" style="padding-top:0"> 
    <div class="grid-3 animate-fade-in delay-2"> 
        <div class="glass-card value-card">
            <div class="vc-icon">📧</div>
            <div class="vc-title">Email Us</div>
            <p class="vc-text">support@campusmart.edu<br>We aim to respond within 24 hours.</p>
        </div> 
        <div class="glass-card value-card">
            <div class="vc-icon">📍</div>
            <div class="vc-title">Visit Us</div>
            <p class="vc-text">Student Union Building, Room 204<br>Monday - Friday, 9AM - 5PM</p>
        </div> 
        <div class="glass-card value-card">
            <div class="vc-icon">💬</div>
            <div class="vc-title">Live Chat</div>
            <p class="vc-text">Available in the app during business hours for immediate assistance.</p>
        </div> 
    </div> 
</section>

<div class="cta"> 
    <h2>Need Immediate Help?</h2> 
    <p>Check out our comprehensive FAQ section for quick answers.</p> 
    <a href="#" class="btn-primary" style="padding:14px 36px; font-size:16px; display:inline-block; text-decoration:none;">Visit Help Center →</a> 
</div>
