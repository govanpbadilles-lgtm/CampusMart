@model CampusMart.Models.ViewModels.User.CartViewModel
@{
    ViewData["Title"] = "Cart";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="cart-container">
    <div class="page-header animate-in">
        <a asp-controller="UserDashboard" asp-action="Index" class="back-btn">←</a>
        <div><h1 class="page-title">Shopping Cart</h1><p class="page-subtitle">@Model.ItemCount items in your cart</p></div>
    </div>

    @if (Model.Items.Any())
    {
        @foreach (var item in Model.Items)
        {
            <div class="cart-item animate-in d1" data-item-id="@item.CartItemId">
                <img src="@(item.ImageUrl ?? "https://via.placeholder.com/80")" alt="@item.ProductName" class="cart-item-img">
                <div class="cart-item-info">
                    <div class="cart-item-name">@item.ProductName</div>
                    <div class="cart-item-meta">@item.CategoryName</div>
                </div>
                <div class="cart-qty">
                    <button data-action="decrease">−</button>
                    <span>@item.Quantity</span>
                    <button data-action="increase">+</button>
                </div>
                <div class="cart-item-price">₱@item.Price.ToString("F2")</div>
                <form asp-controller="Cart" asp-action="RemoveFromCart" method="post" style="display:inline;">
                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                    <button type="submit" class="cart-item-remove" title="Remove">✕</button>
                </form>
            </div>
        }

        <div class="cart-summary animate-in d2">
            <div class="cart-summary-row"><span>Subtotal</span><span id="cartSubtotal">₱@Model.Subtotal.ToString("F2")</span></div>
            <div class="cart-summary-row"><span>Platform Fee</span><span style="color:#4ade80;">Free</span></div>
            <div class="cart-summary-row total"><span>Total</span><span id="cartTotal">₱@Model.Subtotal.ToString("F2")</span></div>
            <a asp-controller="Order" asp-action="Checkout" class="btn-checkout" style="display:block;text-align:center;text-decoration:none;">Proceed to Checkout</a>
            <a asp-controller="UserDashboard" asp-action="Index" style="display:block;text-align:center;color:var(--text-muted);font-size:13px;margin-top:12px;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--text-muted)'">
                ← Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="cart-empty animate-in d1">
            <span class="cart-empty-icon">🛒</span>
            <h3>Your cart is empty</h3>
            <p>Browse the marketplace to find great deals!</p>
            <a asp-controller="UserDashboard" asp-action="Index" class="btn-enter" style="display:inline-block;margin-top:16px;padding:12px 24px;">Browse Shop</a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/cart.js" asp-append-version="true"></script>
}
